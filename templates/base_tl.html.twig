<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}Traduction Légale — Traducteur Assermenté{% endblock %}</title>
<meta name="description" content="{% block meta_description %}Traducteur assermenté inscrit près de la Cour d'Appel. Traduction certifiée de vos actes officiels, diplômes, jugements et documents juridiques.{% endblock %}">
{% block meta_keywords %}{% endblock %}
<meta name="robots" content="{% block meta_robots %}index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1{% endblock %}">
<meta name="author" content="{% block meta_author %}Traduction Légale{% endblock %}">
<meta name="theme-color" content="#0a2047">
<link rel="canonical" href="{% block canonical %}{{ absolute_url(path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params', {}))) }}{% endblock %}">
<link rel="shortcut icon" href="{{ asset('img/favicon.ico') }}" type="image/x-icon">

{% block social_meta %}{% endblock %}
{% block structured_data %}{% endblock %}
{% block meta_extra %}{% endblock %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('css/traduction-legale.css') }}">
{% block stylesheets %}{% endblock %}
</head>
<body>

{% include 'partials/tl_header.html.twig' %}

<main id="top">
{% block body %}{% endblock %}
</main>

{% include 'partials/tl_footer.html.twig' %}

<script src="{{ asset('js/traduction-legale.js') }}" defer></script>
{% block javascripts %}{% endblock %}

</body>
</html>
