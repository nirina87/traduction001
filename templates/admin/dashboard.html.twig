{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}{% endblock %}

{% block content_header_wrapper %}{% endblock %}

{% block body_class %}page-content page-dashboard{% endblock %}

{% block main %}
<div class="admin-dashboard">

    <div class="admin-topbar">
        <div>
            <h1>Tableau de bord</h1>
            <p class="subtitle">Vue d'ensemble — {{ 'now'|date('l d F Y')|capitalize }}</p>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="label">Messages reçus</div>
            <div class="value">{{ stats.contacts }}</div>
            <div class="delta up">demandes de contact</div>
        </div>
        <div class="kpi-card">
            <div class="label">Documents clients</div>
            <div class="value">{{ stats.clientDocuments }}</div>
        </div>
        <div class="kpi-card">
            <div class="label">CA du mois</div>
            <div class="value">{{ stats.monthlyRevenue|number_format(0, ',', ' ') }} €</div>
            <div class="delta up">{{ stats.monthlyPaidOrders }} commande{{ stats.monthlyPaidOrders > 1 ? 's' : '' }} payée{{ stats.monthlyPaidOrders > 1 ? 's' : '' }}</div>
        </div>
        <div class="kpi-card">
            <div class="label">Délai moyen livraison</div>
            <div class="value">1,8 j</div>
            <div class="delta down">objectif : 2 j max</div>
        </div>
    </div>

    <section class="admin-panel" id="contacts">
        <div class="admin-panel-head">
            <h2>Messages récents</h2>
            <a class="btn btn-outline btn-sm" href="{{ ea_url().setController('App\\Controller\\Admin\\ContactCrudController').setAction('index') }}">Voir tout</a>
        </div>
        {% if recentContacts is not empty %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Réf.</th>
                        <th>Contact</th>
                        <th>Coordonnées</th>
                        <th>Message</th>
                        <th>Statut</th>
                        <th>Reçu le</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for contact in recentContacts %}
                        <tr>
                            <td class="mono">CT-{{ '%04d'|format(contact.id) }}</td>
                            <td>{{ contact.prenom }} {{ contact.nom }}</td>
                            <td>
                                <div class="mono">{{ contact.email }}</div>
                                {% if contact.telephone %}
                                    <div class="mono">{{ contact.telephone }}</div>
                                {% endif %}
                            </td>
                            <td>{{ contact.message|slice(0, 60) }}{% if contact.message|length > 60 %}…{% endif %}</td>
                            <td><span class="pill pill-new">Nouveau</span></td>
                            <td class="mono">{{ contact.createdAt|date('d/m/Y') }}</td>
                            <td class="admin-actions">
                                <a class="icon-btn" href="{{ ea_url().setController('App\\Controller\\Admin\\ContactCrudController').setAction('edit').setEntityId(contact.id) }}" aria-label="Voir le message">↗</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="admin-empty">Aucun message reçu pour le moment</div>
        {% endif %}
    </section>

    <section class="admin-panel">
        <div class="admin-panel-head">
            <h2>Documents clients récents</h2>
            <a class="btn btn-outline btn-sm" href="{{ ea_url().setController('App\\Controller\\Admin\\ClientDocumentCrudController').setAction('index') }}">Voir tout</a>
        </div>
        {% if recentClientDocuments is not empty %}
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Réf.</th>
                        <th>Titre</th>
                        <th>Langue</th>
                        <th>Statut</th>
                        <th>Nbre de page</th>
                        <th>Reçu le</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for doc in recentClientDocuments %}
                        <tr>
                            <td class="mono">DC-{{ '%04d'|format(doc.id) }}</td>
                            <td>{{ doc.title }}</td>
                            <td class="mono">{{ doc.language ?: '—' }}</td>
                            <td>{% include 'admin/client_document/_workflow_status_select.html.twig' with { doc: doc } %}</td>
                            <td class="mono">{{ doc.pageCount }}</td>
                            <td class="mono">{{ doc.uploadedAt ? doc.uploadedAt|date('d/m/Y') : '—' }}</td>
                            <td class="admin-actions">
                                <a class="icon-btn" href="{{ ea_url().setController('App\\Controller\\Admin\\ClientDocumentCrudController').setAction('detail').setEntityId(doc.id) }}" aria-label="Voir le document">↗</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="admin-empty">Aucun document client reçu</div>
        {% endif %}
    </section>

    <section class="admin-panel">
        <div class="admin-panel-head">
            <h2>Répartition par secteur — 30 derniers jours</h2>
        </div>
        <div class="sector-bars">
            <div>
                <div class="sector-bar-row">
                    <span>Avocats &amp; cabinets</span>
                    <span class="mono">48 %</span>
                </div>
                <div class="sector-bar-track">
                    <div class="sector-bar-fill sector-bar-fill--wine" style="width:48%"></div>
                </div>
            </div>
            <div>
                <div class="sector-bar-row">
                    <span>Administrations</span>
                    <span class="mono">32 %</span>
                </div>
                <div class="sector-bar-track">
                    <div class="sector-bar-fill sector-bar-fill--gold" style="width:32%"></div>
                </div>
            </div>
            <div>
                <div class="sector-bar-row">
                    <span>Associations &amp; ONG</span>
                    <span class="mono">20 %</span>
                </div>
                <div class="sector-bar-track">
                    <div class="sector-bar-fill sector-bar-fill--ink" style="width:20%"></div>
                </div>
            </div>
        </div>
    </section>

</div>
{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    {% include 'admin/client_document/_workflow_status_script.html.twig' %}
{% endblock %}
