{% block content %}
    <style>
        *{
            font-family: Arial;
        }
        .dashboard-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem;
            border-radius: 10px;
            margin-bottom: 2rem;
        }
        
        .dashboard-header h1 {
            margin: 0 0 0.5rem 0;
            font-size: 2rem;
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .stats-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            text-align: center;
            transition: transform 0.3s ease;
        }
        
        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.15);
        }
        
        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            color: #667eea;
            margin: 1rem 0;
        }
        
        .stat-label {
            color: #666;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .stat-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .action-button {
            display: inline-block;
            margin-top: 1rem;
            padding: 0.7rem 1.5rem;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s ease;
        }
        
        .action-button:hover {
            background: #764ba2;
            color: white;
        }
        
        .recent-articles {
            background: white;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            padding: 2rem;
        }
        
        .recent-articles h3 {
            margin-top: 0;
            color: #333;
            border-bottom: 2px solid #667eea;
            padding-bottom: 1rem;
        }
        
        .article-item {
            padding: 1rem;
            border-left: 4px solid #667eea;
            margin-bottom: 1rem;
            background: #f9f9f9;
            border-radius: 5px;
        }
        
        .article-item:hover {
            background: #f0f0f0;
        }
        
        .article-title {
            font-weight: bold;
            color: #333;
            margin-bottom: 0.5rem;
        }
        
        .article-meta {
            font-size: 0.9rem;
            color: #999;
        }
        
        .category-badge {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.85rem;
            margin-right: 0.5rem;
        }
        
        .empty-state {
            text-align: center;
            padding: 2rem;
            color: #999;
        }
    </style>

    <div class="dashboard-header">
        <h1>👋 TABLEAU DE BORD</h1>
        <p>Gérez votre contenu et consultez les demandes</p>
    </div>

    <!-- Statistiques Principales -->
    <div class="dashboard-grid">
        <!-- Carte Catégories -->
        <div class="stats-card">
            <div class="stat-icon">📁</div>
            <div class="stat-label">Catégories</div>
            <div class="stat-number">{{ totalCategories }}</div>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('index') }}" class="action-button">
                Gérer
            </a>
        </div>

        <!-- Carte Articles -->
        <div class="stats-card">
            <div class="stat-icon">📄</div>
            <div class="stat-label">Articles</div>
            <div class="stat-number">{{ totalArticles }}</div>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').setAction('index') }}" class="action-button">
                Gérer
            </a>
        </div>

        <!-- Carte Actions Rapides -->
        <div class="stats-card">
            <div class="stat-icon">⚡</div>
            <div class="stat-label">Actions Rapides</div>
            <div style="margin-top: 1.5rem;">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('new') }}" class="action-button" style="display: block; margin-bottom: 0.5rem;">
                    ➕ Catégorie
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').setAction('new') }}" class="action-button" style="display: block;">
                    ➕ Article
                </a>
            </div>
        </div>
    </div>
    <div class="recent-articles">
    <h3>📩 Derniers contacts</h3>

    <div style="overflow-x:auto;">
        <table class="table" style="width:100%; border-collapse: collapse;">
            <thead>
                <tr style="background:#667eea; color:white;">
                    <th style="padding:10px;">Nom</th>
                    <th style="padding:10px;">Email</th>
                    <th style="padding:10px;">Téléphone</th>
                    <th style="padding:10px;">Message</th>
                    <th style="padding:10px;">Date</th>
                </tr>
            </thead>
            <tbody>
                {% for contact in contacts %}
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:10px;">{{ contact.nom }}</td>
                        <td style="padding:10px;">{{ contact.email }}</td>
                        <td style="padding:10px;">{{ contact.telephone }}</td>
                        <td style="padding:10px;">
                            {{ contact.message|slice(0, 50) }}...
                        </td>
                        <td style="padding:10px;">
                            {{ contact.created_at|date('d/m/Y H:i') }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="empty-state">
                            Aucun contact
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div> <a href="{{ ea_url().setController('App\\Controller\\Admin\\ContactCrudController').setAction('index') }}"
    style="color: #fff; background: #25992a; text-decoration: none; padding: 11px 20px;
    border-radius: 40px;
    margin: 10px 0 0 0;
    display: block;
    width: 230px;
    font-size: 14px; text-align:center"
    >Voir tous les contacts</a> </div>
</div>

    
{% endblock %}