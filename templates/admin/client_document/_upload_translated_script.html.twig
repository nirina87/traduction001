<script>
document.addEventListener('DOMContentLoaded', function () {
    const card = document.getElementById('doc-translated-file-card');
    const triggerButton = document.getElementById('doc-upload-translated-button');
    const uploadAction = document.getElementById('doc-upload-translated-action');
    const modalElement = document.getElementById('doc-upload-translated-modal');
    const form = document.getElementById('doc-upload-translated-form');
    const fileInput = document.getElementById('doc-upload-translated-input');
    const pageAfterTranslationInput = document.getElementById('doc-upload-page-after-translation');
    const submitButton = document.getElementById('doc-upload-translated-submit');
    const currentContainer = document.getElementById('doc-translated-file-current');
    const feedback = document.getElementById('doc-upload-translated-feedback');
    const cardFeedback = document.getElementById('doc-upload-translated-card-feedback');

    if (!card || !modalElement || !form || !fileInput || !pageAfterTranslationInput || !submitButton || !currentContainer || typeof bootstrap === 'undefined') {
        return;
    }

    const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
    const uploadUrl = form.dataset.url || '';

    if (triggerButton) {
        triggerButton.addEventListener('click', function () {
            resetFormState();
            modal.show();
        });
    }

    modalElement.addEventListener('hidden.bs.modal', function () {
        resetFormState();
    });

    form.addEventListener('submit', async function (event) {
        event.preventDefault();

        if (!uploadUrl) {
            showFeedback('URL d\'upload indisponible.', true);
            return;
        }

        if (!fileInput.files || !fileInput.files[0]) {
            showFeedback('Veuillez sélectionner un fichier.', true);
            return;
        }

        const pageAfterTranslation = Math.max(1, Math.min(99, parseInt(pageAfterTranslationInput.value, 10) || 1));
        pageAfterTranslationInput.value = String(pageAfterTranslation);

        const formData = new FormData();
        formData.append('file', fileInput.files[0]);
        formData.append('pageAfterTranslation', String(pageAfterTranslation));

        const entityId = form.dataset.entityId || '';
        if (entityId) {
            formData.append('entityId', entityId);
        }

        submitButton.disabled = true;
        submitButton.textContent = 'Enregistrement…';
        showFeedback('', false);

        try {
            const response = await fetch(uploadUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                },
                body: formData,
            });

            const contentType = response.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                throw new Error('Réponse serveur invalide.');
            }

            const payload = await response.json();
            if (!response.ok || !payload.success) {
                throw new Error(payload.message || 'Impossible d\'enregistrer le document traduit.');
            }

            if (payload.html) {
                currentContainer.innerHTML = payload.html;
            }

            if (typeof payload.pageAfterTranslation === 'number') {
                form.dataset.pageAfterTranslation = String(payload.pageAfterTranslation);
            }

            hideUploadAction();
            updateVolumeKpi(payload.pageAfterTranslation);
            modal.hide();
            showCardFeedback(payload.message || 'Le document traduit a été enregistré.', false);
            updateWorkflowStatus(payload);
        } catch (error) {
            showFeedback(error.message || 'Impossible d\'enregistrer le document traduit.', true);
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = submitButton.dataset.defaultLabel || 'Enregistrer';
        }
    });

    function resetFormState() {
        fileInput.value = '';
        pageAfterTranslationInput.value = form.dataset.pageAfterTranslation || '1';
        showFeedback('', false);
        submitButton.disabled = false;
        submitButton.textContent = submitButton.dataset.defaultLabel || 'Enregistrer';
    }

    function showFeedback(message, isError) {
        if (!feedback) {
            if (message && isError) {
                window.alert(message);
            }
            return;
        }

        feedback.textContent = message;
        feedback.hidden = '' === message;
        feedback.classList.toggle('is-error', !!isError);
        feedback.classList.toggle('is-success', !!message && !isError);
    }

    function showCardFeedback(message, isError) {
        if (!cardFeedback) {
            if (message) {
                window.alert(message);
            }
            return;
        }

        cardFeedback.textContent = message;
        cardFeedback.hidden = '' === message;
        cardFeedback.classList.toggle('is-error', !!isError);
        cardFeedback.classList.toggle('is-success', !!message && !isError);
    }

    function hideUploadAction() {
        card.classList.remove('doc-file-card--no-translated');

        if (uploadAction) {
            uploadAction.remove();
            return;
        }

        if (triggerButton) {
            triggerButton.remove();
        }
    }

    function updateVolumeKpi(pageAfterTranslation) {
        if (typeof pageAfterTranslation !== 'number') {
            return;
        }

        const volumeTranslated = document.getElementById('doc-volume-translated');
        const volumeTranslatedValue = document.getElementById('doc-volume-translated-value');
        const volumeTranslatedLabel = document.getElementById('doc-volume-translated-label');

        if (!volumeTranslated) {
            return;
        }

        if (volumeTranslatedValue) {
            volumeTranslatedValue.textContent = String(pageAfterTranslation);
        }

        if (volumeTranslatedLabel) {
            volumeTranslatedLabel.textContent = pageAfterTranslation > 1 ? 'pages traduites' : 'page traduite';
        }

        volumeTranslated.hidden = false;
    }

    function updateWorkflowStatus(payload) {
        if (!payload.workflowStatus) {
            return;
        }

        const workflowSelect = document.querySelector('.ea-workflow-status-select');
        if (workflowSelect) {
            workflowSelect.value = payload.workflowStatus;
            workflowSelect.dataset.previousValue = payload.workflowStatus;
            workflowSelect.className = 'ea-workflow-status-select ea-workflow-status-select--' + payload.workflowStatus;
        }

        const statusPill = document.querySelector('.kpi-card .pill');
        if (statusPill && payload.workflowStatusLabel && payload.workflowStatusPillClass) {
            statusPill.textContent = payload.workflowStatusLabel;
            statusPill.className = 'pill ' + payload.workflowStatusPillClass;
        }
    }
});
</script>
