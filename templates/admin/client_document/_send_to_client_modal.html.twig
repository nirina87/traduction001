<div id="doc-send-to-client-modal" class="modal fade doc-delete-modal" tabindex="-1" aria-labelledby="doc-send-to-client-modal-heading" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="doc-send-to-client-modal-heading">Envoyer au client</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="doc-delete-modal__message" id="doc-send-to-client-modal-message">
                    Confirmez l'envoi du document traduit au client par e-mail.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline btn-sm doc-delete-modal__cancel" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btn btn-sm doc-delete-modal__confirm doc-send-modal__confirm" id="doc-send-to-client-modal-confirm">
                    Confirmer l'envoi
                </button>
            </div>
        </div>
    </div>
</div>
