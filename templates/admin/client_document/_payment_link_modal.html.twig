<div id="doc-payment-link-modal" class="modal fade doc-delete-modal doc-payment-link-modal" tabindex="-1" aria-labelledby="doc-payment-link-modal-heading" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="doc-payment-link-modal-heading">Créer et envoyer le lien de paiement</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="doc-payment-link-modal__intro">
                    Un lien de paiement sécurisé sera généré et envoyé automatiquement par e-mail au client pour régler ce dossier.
                </p>
                {% if user and user.email %}
                    <p class="doc-payment-link-modal__recipient">
                        Destinataire : <span class="mono">{{ user.email }}</span>
                    </p>
                {% endif %}
                <div class="doc-payment-link-modal__amount doc-create-form__field">
                    <label for="doc-payment-link-modal-amount">Montant (€)</label>
                    <input
                        type="number"
                        id="doc-payment-link-modal-amount"
                        class="doc-payment-link-modal__amount-input mono"
                        min="0.01"
                        step="0.01"
                        value="{{ (priceCents / 100)|number_format(2, '.', '') }}"
                        required
                    >
                    <p class="doc-create-form__hint">Vous pouvez ajuster le montant avant l'envoi du lien de paiement.</p>
                </div>
                {% if doc.receiveByPaper %}
                    <p class="doc-payment-link-modal__hint">
                        Livraison par courrier incluse dans le montant.
                    </p>
                {% endif %}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline btn-sm doc-delete-modal__cancel" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button
                    type="button"
                    class="btn btn-sm doc-delete-modal__confirm doc-payment-link-modal__confirm"
                    id="doc-payment-link-modal-confirm"
                >
                    Créer et envoyer
                </button>
            </div>
        </div>
    </div>
</div>
