<div class="ea-payment-legend" role="note" aria-label="Légende des statuts de paiement">
    <p class="ea-payment-legend__title">Légende des statuts</p>
    <div class="ea-payment-legend__items">
        <div class="ea-payment-legend__item">
            <span class="ea-payment-status ea-payment-status--paid">
                <span class="ea-payment-status__dot" aria-hidden="true"></span>
                <span class="ea-payment-status__label">Payé</span>
            </span>
            <p class="ea-payment-legend__description">Le document est rattaché à une commande dont le paiement a été confirmé.</p>
        </div>
        <div class="ea-payment-legend__item">
            <span class="ea-payment-status ea-payment-status--pending">
                <span class="ea-payment-status__dot" aria-hidden="true"></span>
                <span class="ea-payment-status__label">Paiement en attente</span>
            </span>
            <p class="ea-payment-legend__description">Le document est lié à une commande, mais le paiement n’a pas encore été finalisé.</p>
        </div>
        <div class="ea-payment-legend__item">
            <span class="ea-payment-status ea-payment-status--none">
                <span class="ea-payment-status__dot" aria-hidden="true"></span>
                <span class="ea-payment-status__label">Non rattaché</span>
            </span>
            <p class="ea-payment-legend__description">Le document a été envoyé mais n’est rattaché à aucune commande pour le moment.</p>
        </div>
    </div>
</div>
