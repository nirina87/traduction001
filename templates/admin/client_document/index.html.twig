{% extends '@EasyAdmin/crud/index.html.twig' %}

{% set stats = indexStats|default({ total: 0, unpaid: 0, inProgress: 0, delivered: 0 }) %}

{% block body_class %}page-content page-doc-index ea-index ea-index-ClientDocument{% endblock %}

{% block page_title %}Documents clients{% endblock %}
{% block content_title %}{% endblock %}
{% block content_header_wrapper %}{% endblock %}
{% block page_actions %}{% endblock %}

{% block entity_actions %}{% endblock %}

{% block table_body_empty %}
    <tr class="doc-index-empty-row">
        <td colspan="100">
            <div class="admin-empty">Aucun document client pour le moment</div>
        </td>
    </tr>
{% endblock %}

{% block main %}
<div class="admin-dashboard admin-doc-index">

    <div class="admin-topbar">
        <div>
            <a class="doc-back-link" href="{{ path('admin') }}">
                ← Tableau de bord
            </a>
            <h1>Documents clients</h1>
            <p class="subtitle">Gestion des dossiers — {{ stats.total }} document{{ stats.total > 1 ? 's' : '' }} au total</p>
        </div>
        <div class="admin-topbar-actions">
            <button
                type="button"
                class="btn btn-sm doc-create-button"
                id="doc-create-button"
                data-url="{{ createClientDocumentUrl|default('') }}"
            >
                + Nouveau dossier
            </button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="label">Total dossiers</div>
            <div class="value">{{ stats.total }}</div>
            <div class="delta">documents enregistrés</div>
        </div>
        <div class="kpi-card">
            <div class="label">Non payés</div>
            <div class="value">{{ stats.unpaid }}</div>
            <div class="delta down">en attente de règlement</div>
        </div>
        <div class="kpi-card">
            <div class="label">En cours</div>
            <div class="value">{{ stats.inProgress }}</div>
            <div class="delta">traduction en cours</div>
        </div>
        <div class="kpi-card">
            <div class="label">Livrés</div>
            <div class="value">{{ stats.delivered }}</div>
            <div class="delta up">dossiers finalisés</div>
        </div>
    </div>

    <section class="admin-panel">
        <div class="admin-panel-head">
            <h2>Liste des documents</h2>
        </div>

        <div class="doc-index-table-wrap">
            {{ parent() }}
        </div>
    </section>

</div>

{% include 'admin/client_document/_create_modal.html.twig' %}
{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    {% include 'admin/client_document/_workflow_status_script.html.twig' %}
    {% include 'admin/client_document/_create_script.html.twig' %}
{% endblock %}
