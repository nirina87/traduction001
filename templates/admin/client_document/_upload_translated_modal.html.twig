{% set uploadTranslatedUrl = ea_url()
    .setController('App\\Controller\\Admin\\ClientDocumentCrudController')
    .setAction('uploadTranslatedDocument')
    .setEntityId(doc.id) %}

<div id="doc-upload-translated-modal" class="modal fade doc-upload-translated-modal doc-create-modal" tabindex="-1" aria-labelledby="doc-upload-translated-modal-heading" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="doc-upload-translated-modal-heading">Enregistrer le fichier traduit</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <form
                id="doc-upload-translated-form"
                class="doc-upload-translated-form"
                data-url="{{ uploadTranslatedUrl }}"
                data-entity-id="{{ doc.id }}"
                data-page-after-translation="{{ doc.pageAfterTranslation }}"
            >
                <div class="modal-body">
                    <div class="doc-create-form__field doc-create-form__field--full">
                        <label for="doc-upload-translated-input">Déposer ou remplacer la traduction <span class="required">*</span></label>
                        <input
                            type="file"
                            id="doc-upload-translated-input"
                            name="file"
                            accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                            required
                        >
                        <p class="doc-create-form__hint">PDF, Word ou image — remplace le fichier existant le cas échéant.</p>
                    </div>
                    <div class="doc-create-form__field">
                        <label for="doc-upload-page-after-translation">Nombre de page après traduction <span class="required">*</span></label>
                        <input
                            type="number"
                            id="doc-upload-page-after-translation"
                            name="pageAfterTranslation"
                            min="1"
                            max="99"
                            value="{{ doc.pageAfterTranslation }}"
                            required
                        >
                    </div>
                    <p id="doc-upload-translated-feedback" class="doc-upload-translated-form__feedback" hidden role="alert"></p>
                </div>
                <div class="modal-footer doc-create-modal__footer">
                    <div class="doc-create-modal__footer-actions">
                        <button type="button" class="btn btn-outline btn-sm doc-create-modal__cancel" data-bs-dismiss="modal">
                            Annuler
                        </button>
                        <button
                            type="submit"
                            class="btn btn-sm doc-create-modal__confirm"
                            id="doc-upload-translated-submit"
                            data-default-label="Enregistrer"
                        >
                            Enregistrer
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
