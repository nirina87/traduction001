{% extends '@EasyAdmin/crud/index.html.twig' %}

{% set stats = indexStats|default({ total: 0, thisWeek: 0, thisMonth: 0, withPhone: 0 }) %}

{% block body_class %}page-content page-contact-index ea-index ea-index-Contact{% endblock %}

{% block page_title %}Messages reçus{% endblock %}
{% block content_title %}{% endblock %}
{% block content_header_wrapper %}{% endblock %}
{% block page_actions %}{% endblock %}

{% block entity_actions %}{% endblock %}

{% block table_body_empty %}
    <tr class="contact-index-empty-row">
        <td colspan="100">
            <div class="admin-empty">Aucun message reçu pour le moment</div>
        </td>
    </tr>
{% endblock %}

{% block main %}
<div class="admin-dashboard admin-contact-index">

    <div class="admin-topbar">
        <div>
            <a class="doc-back-link" href="{{ path('admin') }}">
                ← Tableau de bord
            </a>
            <h1>Messages reçus</h1>
            <p class="subtitle">Demandes de contact — {{ stats.total }} message{{ stats.total > 1 ? 's' : '' }} au total</p>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="label">Total messages</div>
            <div class="value">{{ stats.total }}</div>
            <div class="delta">demandes enregistrées</div>
        </div>
        <div class="kpi-card">
            <div class="label">Cette semaine</div>
            <div class="value">{{ stats.thisWeek }}</div>
            <div class="delta up">nouveaux messages</div>
        </div>
        <div class="kpi-card">
            <div class="label">Ce mois-ci</div>
            <div class="value">{{ stats.thisMonth }}</div>
            <div class="delta">sur les 30 derniers jours</div>
        </div>
        <div class="kpi-card">
            <div class="label">Avec téléphone</div>
            <div class="value">{{ stats.withPhone }}</div>
            <div class="delta">rappel possible</div>
        </div>
    </div>

    <section class="admin-panel">
        <div class="admin-panel-head">
            <h2>Liste des messages</h2>
        </div>

        <div class="contact-index-table-wrap">
            {{ parent() }}
        </div>
    </section>

</div>
{% endblock %}
