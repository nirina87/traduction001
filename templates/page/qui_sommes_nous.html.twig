{% extends 'base.html.twig' %}

{% block title %}Qui sommes-nous{% endblock %}

{% block body %}
    <!-- Page Header Start -->
    <div class="page-header parallaxie">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <!-- Page Header Box Start -->
                    <div class="page-header-box">
                        <h1 class="text-anime-style-2" data-cursor="-opaque">Qui sommes-nous</h1>
                        <nav class="wow fadeInUp">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('accueil') }}">Accueil</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Qui sommes-nous</li>
                            </ol>
                        </nav>
                    </div>
                    <!-- Page Header Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End -->

    <!-- Our Approach Section Start -->
    <div class="our-approach light-bg-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <!-- Approach Images Start -->
                    <div class="approach-images">
                        <div class="approach-img-1">
                            <figure class="image-anime reveal">
                                <img src="{{ asset('extermination-prevention-nuisible-1.jpg') }}" alt="Dératisation et désinsectisation">
                            </figure>
                        </div>

                        <div class="approach-image-counter">
                            <div class="approach-img-2">
                                <figure class="image-anime">
                                    <img src="{{ asset('extermination-prevention-nuisible-2.jpg') }}" alt="Intervention nuisibles">
                                </figure>
                            </div>

                            <div class="experience-box">
                                <div class="icon-box">
                                    <img src="{{ asset('images/icon-experience.svg') }}" alt="">
                                </div>
                                <div class="experience-content">
                                    <h2>+<span class="counter">26</span></h2>
                                    <p>Années d'expérience</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Approach Images End -->
                </div>

                <div class="col-lg-6">
                    <!-- Approach Content Start -->
                    <div class="approach-content">

                        <div class="section-title">
                            <h3 class="wow fadeInUp">Notre expertise</h3>
                            <h2 class="text-anime-style-2">
                                ESPACE HYGIENE 3D – <span>Extermination & prévention des nuisibles</span>
                            </h2>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">
                                Basée à Sucy-en-Brie, ESPACE HYGIENE 3D est spécialisée dans la lutte contre les nuisibles à Paris et en Île-de-France. 
                                Nous intervenons rapidement pour éliminer durablement rats, souris, insectes et autres parasites, 
                                tout en garantissant des solutions efficaces, discrètes et respectueuses de votre environnement.
                            </p>
                        </div>

                        <!-- Vision Mission Boxes Start -->
                        <div class="vision-mission-boxes">

                            <div class="vision-mission-item wow fadeInUp" data-wow-delay="0.2s">
                                <div class="vision-mission-content">
                                    <h3>Notre vision</h3>
                                    <p>
                                        Devenir une référence en Île-de-France dans la gestion des nuisibles, 
                                        en alliant efficacité, innovation et respect des normes sanitaires.
                                    </p>
                                </div>
                                <div class="vision-mission-image">
                                    <figure class="image-anime">
                                        <img src="{{ asset('entreprise-espace-hygiene-3d-2.jpg') }}" alt="">
                                    </figure>
                                </div>
                            </div>

                            <div class="vision-mission-item wow fadeInUp" data-wow-delay="0.4s">
                                <div class="vision-mission-content">
                                    <h3>Notre mission</h3>
                                    <p>
                                        Protéger les particuliers et professionnels grâce à des interventions, 
                                        des traitements efficaces et un suivi pour éviter toute réinfestation.
                                    </p>
                                </div>
                                <div class="vision-mission-image">
                                    <figure class="image-anime">
                                        <img src="{{ asset('entreprise-espace-hygiene-3d-1.jpg') }}" alt="">
                                    </figure>
                                </div>
                            </div>

                        </div>
                        <!-- Vision Mission Boxes End -->

                        <!-- Approach List Start -->
                        <div class="approach-list wow fadeInUp" data-wow-delay="0.6s">
                            <ul>
                                <li>Intervention rapide à Paris et en Île-de-France</li>
                                <li>Traitements professionnels contre rats, souris, cafards, punaises de lit, etc.</li>
                                <li>Solutions durables et respectueuses des normes sanitaires</li>
                                <li>Diagnostic précis et accompagnement personnalisé</li>
                            </ul>
                        </div>
                        <!-- Approach List End -->
                        <!-- Approach Button Start -->
                        <div class="approach-button wow fadeInUp" data-wow-delay="0.8s">
                            <a href="{{ path('contact') }}" class="btn-default">Demander une intervention</a>
                        </div>
                        <!-- Approach Button End -->

                    </div>
                    <!-- Approach Content End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Our Approach Section End -->

    <!-- Our Passion Section Start -->
    <div class="our-passion">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <!-- Passion Image Content Start -->
                    <div class="passion-image-content">
                        <!-- Section Title Start -->
                        <div class="section-title">
                            <h3 class="wow fadeInUp">Ce qui nous anime</h3>
                            <h2 class="text-anime-style-2" data-cursor="-opaque">Passion pour l'innovation et le <span>service de qualité</span></h2>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">Nous sommes animés par un engagement à fournir des solutions innovantes, fiables et de haute qualité pour le contrôle des parasites qui garantissent des résultats durables.</p>
                        </div>
                        <!-- Section Title End -->

                        <!-- Passion Image Start -->
                        <div class="passion-image">
                            <figure class="image-anime reveal">
                                <img src="{{ asset('extermination-prevention-nuisible-4.jpg') }}" alt="">
                            </figure>
                        </div>
                        <!-- Passion Image End -->
                    </div>
                    <!-- Passion Image Content End -->
                </div>

                <div class="col-lg-5">
                    <!-- Passion Image List Start -->
                    <div class="passion-image-list">
                        <!-- Passion Image Start -->
                        <div class="passion-image">
                            <figure class="image-anime reveal">
                                <img src="{{ asset('extermination-prevention-nuisible-3.jpg') }}" alt="">
                            </figure>
                        </div>
                        <!-- Passion Image End -->

                        <!-- Passion List Start -->
                        <div class="passion-list wow fadeInUp" data-wow-delay="0.2s">
                            <ul>
                                <li>Expertise en laquelle vous pouvez avoir confiance, soutenue par des années d'expérience.</li>
                                <li>Notre équipe qualifiée offre des solutions cohérentes et fiables.</li>
                                <li>Nous nous engageons à utiliser des méthodes respectueuses de l'environnement.</li>
                                <li>Nous prenons fierté à offrir les meilleurs services de désinsectisation.</li>
                            </ul>
                        </div>
                        <!-- Passion List End -->

                        <!-- Passion Button Start -->
                        <div class="passion-button wow fadeInUp" data-wow-delay="0.4s">
                            <a href="{{ path('contact') }}" class="btn-default">Nous contacter</a>
                        </div>
                        <!-- Passion Button End -->
                    </div>
                    <!-- Passion Image List End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Our Passion Section End -->

    <!-- Why Choose Us Section Start -->
    <div class="why-choose-us light-bg-section">
        <div class="container">
            <div class="row section-row">
                <div class="col-lg-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <h3 class="wow fadeInUp">Pourquoi nous choisir</h3>
                        <h2 class="text-anime-style-2" data-cursor="-opaque">Ce qui fait de nous le meilleur <span>choix pour vous</span></h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s">Nous comprenons à quel point les parasites peuvent être frustrants et perturbants, c'est pourquoi nous nous engageons à fournir des solutions rapides, fiables et efficaces.</p>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- Why Choose Box Start -->
                    <div class="why-choose-box">
                        <!-- Why Choose Item Start -->
                        <div class="why-choose-item wow fadeInUp">
                            <div class="icon-box">
                                <img src="{{ asset('images/icon-why-choose-1.svg') }}" alt="">
                            </div>
                            <div class="why-choose-item-content">
                                <h3>Services d'urgence</h3>
                                <p>Nous sommes disponibles 24h/24 pour répondre à vos besoins urgents.</p>
                            </div>
                        </div>
                        <!-- Why Choose Item End -->

                        <!-- Why Choose Item Start -->
                        <div class="why-choose-item wow fadeInUp" data-wow-delay="0.2s">
                            <div class="icon-box">
                                <img src="{{ asset('images/icon-why-choose-2.svg') }}" alt="">
                            </div>
                            <div class="why-choose-item-content">
                                <h3>Traitements sur mesure</h3>
                                <p>Chaque intervention est adaptée à votre situation spécifique.</p>
                            </div>
                        </div>
                        <!-- Why Choose Item End -->

                        <!-- Why Choose Item Start -->
                        <div class="why-choose-item wow fadeInUp" data-wow-delay="0.4s">
                            <div class="icon-box">
                                <img src="{{ asset('images/icon-why-choose-3.svg') }}" alt="">
                            </div>
                            <div class="why-choose-item-content">
                                <h3>Professionnels certifiés</h3>
                                <p>Notre équipe est formée et certifiée selon les normes les plus strictes.</p>
                            </div>
                        </div>
                        <!-- Why Choose Item End -->

                        <!-- Page Cta Box Start -->
                        <div class="page-cta-box wow fadeInUp" data-wow-delay="0.6s">
                            <!-- Page Cta Box Info Start -->
                            <div class="page-cta-box-info">
                                <h3>Reprenez le contrôle de votre domicile face aux parasites. Aujourd'hui !</h3>
                            </div>
                            <!-- Page Cta Box Info End -->

                            <!-- Page Cta Box Button Start -->
                            <div class="page-cta-box-button">
                                <a href="{{ path('contact') }}" class="btn-default"> Devis </a>
                            </div>
                            <!-- Page Cta Box Button End -->
                        </div>
                        <!-- Page Cta Box End -->
                    </div>
                    <!-- Why Choose Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Why Choose Us Section End -->
{% endblock %}