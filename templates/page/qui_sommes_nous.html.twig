{% extends 'base_tl.html.twig' %}

{% set seo_title = "Qui sommes-nous — Traducteur Assermenté inscrit près d'une Cour d'Appel | Traduction Légale" %}
{% set seo_description = "Traduction Légale : cabinet de traduction assermentée inscrit près de la Cour d'Appel. Rigueur, confidentialité, cachet officiel et reconnaissance par les administrations pour vos documents officiels." %}
{% set seo_keywords = "traducteur assermenté, qui sommes nous, cabinet traduction juridique, cour d'appel, traduction certifiée, traducteur officiel, traduction assermentée france, numéro répertoire traducteur, confidentialité traduction" %}
{% set accueil_url = absolute_url(path('accueil')) %}
{% set page_url = absolute_url(path('qui_sommes_nous')) %}
{% set og_image = absolute_url(asset('logo-tl.png')) %}

{% block title %}{{ seo_title }}{% endblock %}

{% block meta_description %}{{ seo_description }}{% endblock %}

{% block canonical %}{{ page_url }}{% endblock %}

{% block meta_keywords %}
<meta name="keywords" content="{{ seo_keywords }}">
{% endblock %}

{% block social_meta %}
<meta property="og:locale" content="fr_FR">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Traduction Légale">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ seo_description }}">
<meta property="og:url" content="{{ page_url }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:alt" content="Traduction Légale — Cabinet de traduction assermentée inscrit près de la Cour d'Appel">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title }}">
<meta name="twitter:description" content="{{ seo_description }}">
<meta name="twitter:image" content="{{ og_image }}">
<meta name="twitter:image:alt" content="Traduction Légale — Cabinet de traduction assermentée inscrit près de la Cour d'Appel">
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{{ {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': accueil_url ~ '#website',
      'url': accueil_url,
      'name': 'Traduction Légale',
      'description': 'Traducteur assermenté — traduction certifiée de documents officiels',
      'inLanguage': 'fr-FR',
      'publisher': {'@id': accueil_url ~ '#organization'}
    },
    {
      '@type': 'LegalService',
      '@id': accueil_url ~ '#organization',
      'name': 'Traduction Légale — Traducteur Assermenté',
      'url': accueil_url,
      'logo': og_image,
      'image': og_image,
      'description': "Cabinet de traduction assermentée et certifiée de documents officiels, inscrit près d'une Cour d'Appel.",
      'email': 'contact@traductions-legales.fr',
      'priceRange': 'À partir de 28€',
      'areaServed': {
        '@type': 'Country',
        'name': 'France'
      },
      'serviceType': 'Traduction assermentée',
      'availableLanguage': ['fr', 'en', 'es', 'de', 'it'],
      'knowsAbout': [
        'Traduction assermentée',
        'Documents officiels',
        'Traduction juridique',
        'Certification conforme à l\'original',
        'Cour d\'Appel'
      ]
    },
    {
      '@type': 'AboutPage',
      '@id': page_url ~ '#webpage',
      'url': page_url,
      'name': seo_title,
      'description': seo_description,
      'isPartOf': {'@id': accueil_url ~ '#website'},
      'about': {'@id': accueil_url ~ '#organization'},
      'mainEntity': {'@id': accueil_url ~ '#organization'},
      'breadcrumb': {'@id': page_url ~ '#breadcrumb'},
      'inLanguage': 'fr-FR',
      'primaryImageOfPage': {
        '@type': 'ImageObject',
        'url': og_image,
        'caption': 'Traduction Légale — traducteur assermenté'
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': page_url ~ '#breadcrumb',
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Accueil',
          'item': accueil_url
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Qui sommes-nous',
          'item': page_url
        }
      ]
    },
    {
      '@type': 'ItemList',
      '@id': page_url ~ '#engagements',
      'name': 'Nos engagements — Traduction Légale',
      'description': 'Les engagements du cabinet pour chaque dossier de traduction assermentée.',
      'numberOfItems': 6,
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Conformité sans réserve',
          'description': 'Chaque traduction respecte à la lettre la mise en page, les mentions et les cachets du document d\'origine.'
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Confidentialité absolue',
          'description': 'Vos documents et données personnelles sont traités avec la plus stricte discrétion.'
        },
        {
          '@type': 'ListItem',
          'position': 3,
          'name': 'Transparence sur les délais',
          'description': 'Le délai de livraison est communiqué dès le devis et respecté, y compris pour les urgences.'
        },
        {
          '@type': 'ListItem',
          'position': 4,
          'name': 'Responsabilité du traducteur',
          'description': 'Cachet et numéro de répertoire engageant la responsabilité professionnelle sur chaque traduction.'
        },
        {
          '@type': 'ListItem',
          'position': 5,
          'name': 'Tarif clair, sans surprise',
          'description': 'Le prix annoncé au devis est celui facturé, sans supplément en cours de traduction.'
        },
        {
          '@type': 'ListItem',
          'position': 6,
          'name': 'Un interlocuteur, un dossier',
          'description': 'Suivi personnalisé avec un interlocuteur identifié du premier contact à la livraison.'
        }
      ]
    }
  ]
}|json_encode(320)|raw }}
</script>
{% endblock %}

{% block body %}

<div class="page-header" aria-labelledby="page-title">
  <div class="wrap">
    <div>
      <span class="eyebrow">Le cabinet</span>
      <h1 id="page-title">Qui sommes-nous</h1>
    </div>
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="{{ path('accueil') }}">Accueil</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Qui sommes-nous</span>
    </nav>
  </div>
</div>

<section class="about-section" id="mission" aria-labelledby="about-mission-title">
  <div class="wrap">
    <div class="about-hero">
      <div>
        <span class="eyebrow">Notre mission</span>
        <h2 id="about-mission-title">Donner à chaque document traduit la même force que l'original</h2>
        <p>Traduction Légale est un cabinet de traduction assermentée inscrit près d'une Cour d'Appel. Nous traduisons les actes officiels, juridiques et administratifs de particuliers, d'entreprises et de professions juridiques, avec une exigence constante : que la traduction soit reconnue, sans réserve, par l'administration ou la juridiction destinataire.</p>
        <p>Notre approche reste volontairement simple : un tarif annoncé avant traduction, un interlocuteur unique pour chaque dossier, et un cachet qui engage notre responsabilité de traducteur assermenté sur chaque page livrée.</p>
        <p>Depuis nos bureaux, nous traitons des dossiers pour toute la France et pour de nombreuses administrations étrangères, dans des délais compatibles avec les démarches les plus urgentes.</p>
      </div>
      <div class="about-portrait">
        <img src="{{ asset('img/qui-sommes-nous.jpg') }}" alt="Certifiée et reconnue — France et international : documents officiels, domaine juridique, reconnaissance internationale, confidentialité et sécurité" width="918" height="1152" loading="lazy" decoding="async">
      </div>
    </div>
  </div>
</section>

<section class="dossier" id="chiffres" aria-labelledby="about-stats-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">En quelques chiffres</span>
      <h2 id="about-stats-title">Un cabinet à taille humaine, une rigueur de cour d'appel</h2>
    </div>
    <div class="milestones milestones--inverse" role="list" aria-label="Chiffres clés du cabinet">
      <div class="milestone" role="listitem">
        <b>28€</b>
        <span>tarif de base par page</span>
      </div>
      <div class="milestone" role="listitem">
        <b>24–48h</b>
        <span>délai moyen de livraison</span>
      </div>
      <div class="milestone" role="listitem">
        <b>{{ documentCount > 0 ? documentCount ~ '+' : '18+' }}</b>
        <span>types de documents pris en charge</span>
      </div>
      <div class="milestone" role="listitem">
        <b>100%</b>
        <span>traductions certifiées conformes</span>
      </div>
    </div>
  </div>
</section>

<section id="engagements" aria-labelledby="about-values-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Nos engagements</span>
      <h2 id="about-values-title">Ce que vous pouvez attendre de nous, à chaque dossier</h2>
    </div>
    <div class="values-grid" role="list">
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9 12l2 2 4-4M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
        <h3>Conformité sans réserve</h3>
        <p>Chaque traduction respecte à la lettre la mise en page, les mentions et les cachets du document d'origine.</p>
      </article>
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        <h3>Confidentialité absolue</h3>
        <p>Vos documents et données personnelles sont traités avec la même discrétion qu'exigerait votre propre étude notariale.</p>
      </article>
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        <h3>Transparence sur les délais</h3>
        <p>Le délai de livraison vous est communiqué dès le devis, et nous le tenons, y compris pour les dossiers urgents.</p>
      </article>
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
        <h3>Responsabilité du traducteur</h3>
        <p>Notre cachet et notre numéro de répertoire engagent notre responsabilité professionnelle sur chaque traduction livrée.</p>
      </article>
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M3 7l9-4 9 4-9 4-9-4zm0 0v10l9 4 9-4V7"/></svg>
        <h3>Tarif clair, sans surprise</h3>
        <p>Le prix annoncé au devis est celui que vous payez : aucun supplément n'est ajouté en cours de traduction.</p>
      </article>
      <article class="value-card" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v7a2 2 0 01-2 2z"/></svg>
        <h3>Un interlocuteur, un dossier</h3>
        <p>Vous suivez l'avancement de votre traduction avec un interlocuteur identifié, du premier e-mail à la livraison.</p>
      </article>
    </div>
  </div>
</section>

<section class="cta-final" id="contact" aria-labelledby="about-cta-title">
  <div class="wrap">
    <span class="eyebrow eyebrow--light">Travaillons ensemble</span>
    <h2 id="about-cta-title">Confiez-nous votre document, nous nous occupons du reste</h2>
    <p>Un traducteur assermenté étudie votre demande et vous répond avec un devis précis, sans engagement.</p>
    <a href="{{ path('contact') }}" class="btn-primary" aria-label="Contacter Traduction Légale pour un devis de traduction assermentée">
      Nous contacter
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

{% endblock %}
