{% extends 'base.html.twig' %}

{% block title %}Agroalimentaire{% endblock %}

{% block body %}
<!-- Page Header Start -->
<div class="page-header parallaxie">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- Page Header Box Start -->
                <div class="page-header-box">
                    <h1 class="text-anime-style-2" data-cursor="-opaque">Agroalimentaire</h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="{{ path('accueil') }}">Accueil</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Agroalimentaire</li>
                        </ol>
                    </nav>
                </div>
                <!-- Page Header Box End -->
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->
<!-- page Project Single Start -->
    <div class="page-project-single">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <!-- Project Single Content Start -->
                    <div class="project-single-content">
                        <!-- Project Featured Image Start -->
                        <div class="project-featured-image">
                            <figure class="image-anime reveal">
                                <img src="{{ asset('agroalimentaire.jpg') }}" alt="Agroalimentaire - ESPACE HYGIENE 3D">
                            </figure>
                        </div>
                        <!-- Project Featured Image End -->

                        <!-- Project Entry Start -->
                        <div class="project-entry">
                            <p class="wow fadeInUp">
                            Chez <strong>ESPACE HYGIENE 3D</strong>, nous proposons des solutions professionnelles d’extermination des nuisibles spécialement adaptées au secteur agroalimentaire. Dans un environnement où l’hygiène est une priorité absolue, la présence de nuisibles tels que les rongeurs, blattes, insectes volants ou rampants représente un risque majeur pour la sécurité sanitaire, la conformité réglementaire et l’image de votre établissement.
                            </p>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">
                            Nos interventions reposent sur des protocoles stricts respectant les normes HACCP et les exigences des industries agroalimentaires. Nous réalisons un diagnostic complet de vos locaux afin d’identifier les zones à risque, les points d’entrée et les sources d’infestation. Grâce à des traitements ciblés, efficaces et sécurisés, nous assurons une élimination durable des nuisibles tout en garantissant la protection de vos produits et de vos installations.
                            </p>
                            <!-- Project Overview Start -->
                            <div class="project-overview">
                                <h2 class="text-anime-style-2">Hygiène & Sécurité <span>Agroalimentaire</span></h2>
                                <p class="wow fadeInUp" data-wow-delay="0.4s">
                                    Nous accompagnons les entreprises agroalimentaires dans la mise en place de plans de lutte antiparasitaire efficaces et durables. Nos experts interviennent avec des méthodes professionnelles combinant prévention, surveillance et traitement curatif. Chaque solution est adaptée à votre activité (production, stockage, transformation, distribution) afin de garantir un environnement conforme aux normes sanitaires en vigueur.
                                </p>
                                <ul class="wow fadeInUp" data-wow-delay="0.6s">
                                    <li>Respect strict des normes HACCP et exigences sanitaires.</li>
                                    <li>Traitements efficaces contre rongeurs, blattes, insectes et nuisibles alimentaires.</li>
                                    <li>Solutions préventives pour éviter toute recontamination.</li>
                                    <li>Interventions rapides et discrètes adaptées aux environnements sensibles.</li>
                                </ul>
                            </div>
                            <!-- Project Overview End -->

                            <!-- Project Better Homes Start -->
                            <div class="project-better-homes">
                                <h2 class="text-anime-style-2">Maîtrise des nuisibles <span>en milieu sensible</span></h2>
                                <p class="wow fadeInUp" data-wow-delay="0.2s">
                                Chez ESPACE HYGIENE 3D, nous comprenons les enjeux critiques liés à la présence de nuisibles dans l’agroalimentaire. C’est pourquoi nous mettons en place des solutions sur mesure, alliant efficacité, traçabilité et respect des normes environnementales. Nos équipes assurent un suivi rigoureux avec des rapports détaillés pour garantir la conformité lors des audits et contrôles sanitaires.
                                </p>

                                <ul class="wow fadeInUp" data-wow-delay="0.4s">
                                    <li>Audit complet et diagnostic des risques.</li>
                                    <li>Plan de prévention personnalisé.</li>
                                    <li>Suivi régulier et traçabilité des interventions.</li>
                                    <li>Utilisation de produits homologués et sécurisés.</li>
                                    <li>Accompagnement lors des contrôles sanitaires.</li>
                                </ul>
                            </div>
                            <!-- Project Better Homes End -->
                        </div>
                        <!-- Project Entry End -->

                        <!-- FAQs section start -->
                        <div class="page-single-faqs page-faq-accordion">
                            <div class="section-title">
                                <h2 class="text-anime-style-2" data-cursor="-opaque">
                                    Questions fréquentes sur la <span>lutte antiparasitaire agroalimentaire</span>
                                </h2>
                            </div>

                            <div class="faq-accordion" id="accordion">

                                <!-- FAQ 1 -->
                                <div class="accordion-item wow fadeInUp">
                                    <h2 class="accordion-header" id="heading1">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1">
                                            1. Quels nuisibles traitez-vous dans l’agroalimentaire ?
                                        </button>
                                    </h2>
                                    <div id="collapse1" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <p>
                                                Nous intervenons contre tous les nuisibles critiques en milieu agroalimentaire : rongeurs (rats, souris), blattes, insectes volants, mites alimentaires, fourmis et autres parasites pouvant contaminer les denrées et les surfaces de production.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- FAQ 2 -->
                                <div class="accordion-item wow fadeInUp" data-wow-delay="0.2s">
                                    <h2 class="accordion-header" id="heading2">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2">
                                            2. Vos traitements sont-ils compatibles avec les normes HACCP ?
                                        </button>
                                    </h2>
                                    <div id="collapse2" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <p>
                                                Oui, toutes nos interventions respectent strictement les normes HACCP et les exigences sanitaires en vigueur. Nous utilisons des produits homologués et des méthodes adaptées aux environnements sensibles afin de garantir la sécurité alimentaire.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- FAQ 3 -->
                                <div class="accordion-item wow fadeInUp" data-wow-delay="0.4s">
                                    <h2 class="accordion-header" id="heading3">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3">
                                            3. À quelle fréquence faut-il réaliser un traitement ?
                                        </button>
                                    </h2>
                                    <div id="collapse3" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <p>
                                                La fréquence dépend de votre activité et du niveau de risque. En général, un suivi régulier mensuel ou trimestriel est recommandé afin de prévenir toute infestation et garantir une conformité continue lors des audits sanitaires.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- FAQ 4 -->
                                <div class="accordion-item wow fadeInUp" data-wow-delay="0.6s">
                                    <h2 class="accordion-header" id="heading4">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse4">
                                            4. Proposez-vous des interventions d’urgence ?
                                        </button>
                                    </h2>
                                    <div id="collapse4" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <p>
                                                Oui, nous proposons des interventions rapides en cas d’infestation critique afin de limiter les risques de contamination et de garantir la continuité de votre activité.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- FAQ 5 -->
                                <div class="accordion-item wow fadeInUp" data-wow-delay="0.8s">
                                    <h2 class="accordion-header" id="heading5">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse5">
                                            5. Comment détecter une infestation dans un site agroalimentaire ?
                                        </button>
                                    </h2>
                                    <div id="collapse5" class="accordion-collapse collapse">
                                        <div class="accordion-body">
                                            <p>
                                                La présence de traces (excréments, odeurs, dégâts sur les emballages), d’insectes ou de rongeurs visibles, ainsi que des anomalies lors des contrôles qualité sont des signes d’infestation. Nos experts réalisent des audits complets pour détecter et traiter rapidement toute contamination.
                                            </p>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <!-- FAQs section End -->
                    </div>
                    <!-- Project Single Content End -->
                </div>
                <div class="col-lg-4">
                    <!-- Page Single Sidebar Start -->
                    <div class="page-single-sidebar">
                        <div class="page-catagery-list wow fadeInUp">
                            <h3>Nos services</h3>
                            <ul>
                                {% for menu_article in articles %}
                                    <li><a href="/{{ menu_article.category.slug}}/{{ menu_article.slug }}">{{menu_article.title}}</a></li>
                                {% endfor %}
                            </ul>
                            
                        </div>
                        <!-- Page Category List End -->

                        <!-- Sidebar CTA Box Start -->
                        <div class="page-cta-box sidebar-cta-box wow fadeInUp" data-wow-delay="0.2s">
                            <!-- Page Cta Box Info Start -->
                            <div class="page-cta-box-info">
                                <h3><a  href="/contact">Devis gratuit</h3>
                            </div>
                            <!-- Page Cta Box Info End -->
        
                            <!-- Cta Contact Box Start -->
                            <div class="cta-contact-box">
                                <p>Appelez-nous</p>
                                <div class="cta-contact-item">
                                    <div class="icon-box">
                                        <img src="images/icon-cta-phone.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-content">
                                        <h3><a href="tel:+33699474222" onclick="gtag('event', 'conversion', {'send_to': 'AW-775541421/0t-5CP3f0Z8cEK2l5_EC'});">+33 6 99 47 42 22</a></h3>
                                    </div>
                                </div>
                            </div>
                            <!-- Cta Contact Box End -->
                        </div>
                        <!-- Sidebar CTA Box End -->
                    </div>
                    <!-- Page Single Sidebar End -->
                </div>
            </div>
        </div>
    </div>
    <!-- page Project Single End -->

{% endblock %}