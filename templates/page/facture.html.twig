{% extends 'base.html.twig' %}

{% block title %}Facture{% endblock %}

{% block body %}
<div class="main" role="main">
    <section class="section section-no-border pb-0">
        <div class="container py-5">
            <div class="card border-0 shadow rounded-4 p-4 p-lg-5">
                <p class="text-uppercase text-color-primary font-weight-semibold mb-2">Facture</p>
                <h1 class="font-weight-bold text-7 mb-3">Facture {{ order.invoiceNumber }}</h1>
                <p class="text-muted mb-4">Commande passée par {{ order.user.firstName }} {{ order.user.lastName }} — {{ order.user.email }}</p>
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th>Qté</th>
                            <th>PU</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in order.items %}
                            <tr>
                                <td>{{ item.title }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>{{ item.unitPrice }} €</td>
                                <td>{{ item.total }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-3">
                    <strong>Total TTC</strong>
                    <strong>{{ order.total }} €</strong>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
