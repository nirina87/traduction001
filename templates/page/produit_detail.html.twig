{% extends 'base_tl.html.twig' %}

{% set seo_title = product.name ~ " — Traduction Assermentée | Traduction Légale" %}
{% set seo_description = "Commandez la traduction assermentée de votre " ~ product.name|lower ~ ". Traducteur inscrit près de la Cour d'Appel, devis rapide, paiement sécurisé, cachet et certification conforme à l'original." %}
{% set seo_keywords = "traduction assermentée " ~ product.name|lower ~ ", traduction " ~ (product.category|default('document officiel')|lower) ~ ", traducteur cour d'appel, traduction certifiée, commande traduction en ligne" %}
{% set accueil_url = absolute_url(path('accueil')) %}
{% set services_url = absolute_url(path('services')) %}
{% set page_url = absolute_url(path('produit_detail', {id: product.id})) %}
{% set og_image = product.image ? absolute_url(asset('uploads/' ~ product.image)) : absolute_url(asset('logo-tl.png')) %}

{% block title %}{{ seo_title }}{% endblock %}

{% block meta_description %}{{ seo_description }}{% endblock %}

{% block canonical %}{{ page_url }}{% endblock %}

{% block meta_keywords %}
<meta name="keywords" content="{{ seo_keywords }}">
{% endblock %}

{% block social_meta %}
<meta property="og:locale" content="fr_FR">
<meta property="og:type" content="product">
<meta property="og:site_name" content="Traduction Légale">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ seo_description }}">
<meta property="og:url" content="{{ page_url }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:alt" content="Traduction assermentée — {{ product.name }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title }}">
<meta name="twitter:description" content="{{ seo_description }}">
<meta name="twitter:image" content="{{ og_image }}">
<meta name="twitter:image:alt" content="Traduction assermentée — {{ product.name }}">
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{{ {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': accueil_url ~ '#website',
      'url': accueil_url,
      'name': 'Traduction Légale',
      'inLanguage': 'fr-FR',
      'publisher': {'@id': accueil_url ~ '#organization'}
    },
    {
      '@type': 'LegalService',
      '@id': accueil_url ~ '#organization',
      'name': 'Traduction Légale — Traducteur Assermenté',
      'url': accueil_url,
      'logo': absolute_url(asset('logo-tl.png')),
      'email': 'contact@traduction-legale.fr',
      'serviceType': 'Traduction assermentée'
    },
    {
      '@type': 'WebPage',
      '@id': page_url ~ '#webpage',
      'url': page_url,
      'name': seo_title,
      'description': seo_description,
      'isPartOf': {'@id': accueil_url ~ '#website'},
      'about': {'@id': page_url ~ '#product'},
      'breadcrumb': {'@id': page_url ~ '#breadcrumb'},
      'inLanguage': 'fr-FR',
      'primaryImageOfPage': {
        '@type': 'ImageObject',
        'url': og_image,
        'caption': 'Traduction assermentée — ' ~ product.name
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': page_url ~ '#breadcrumb',
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Accueil',
          'item': accueil_url
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Services',
          'item': services_url
        },
        {
          '@type': 'ListItem',
          'position': 3,
          'name': product.name,
          'item': page_url
        }
      ]
    },
    {
      '@type': 'Service',
      '@id': page_url ~ '#product',
      'name': 'Traduction assermentée — ' ~ product.name,
      'description': seo_description,
      'url': page_url,
      'image': og_image,
      'provider': {'@id': accueil_url ~ '#organization'},
      'serviceType': product.category|default('Traduction assermentée'),
      'offers': {
        '@type': 'Offer',
        'url': page_url,
        'priceCurrency': 'EUR',
        'price': product.basePrice ?? 28,
        'availability': 'https://schema.org/InStock'
      }
    }
  ]
}|json_encode(320)|raw }}
</script>
{% endblock %}

{% block body %}

<div class="page-header" aria-labelledby="page-title">
  <div class="wrap">
    <div>
      <span class="eyebrow">{{ product.category|default('Traduction assermentée') }}</span>
      <h1 id="page-title">{{ product.name }}</h1>
    </div>
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="{{ path('accueil') }}">Accueil</a>
      <span aria-hidden="true">›</span>
      <a href="{{ path('services') }}">Services</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{{ product.name }}</span>
    </nav>
  </div>
</div>

<section class="product-detail" aria-labelledby="product-detail-title">
  <div class="wrap">
    <h2 id="product-detail-title" class="visually-hidden">Détail et commande — {{ product.name }}</h2>

    {% for message in app.flashes('success') %}
      <div class="tl-flash tl-flash--success" role="alert">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
      <div class="tl-flash tl-flash--error" role="alert">{{ message }}</div>
    {% endfor %}

    <div class="product-detail-grid">
      <div class="product-detail-main">
        <div class="product-detail-visual">
          {% if product.image %}
            <img
              src="{{ asset('uploads/' ~ product.image) }}"
              alt="Traduction assermentée — {{ product.name }}"
              loading="lazy"
              width="560"
              height="360"
            >
          {% else %}
            <div class="product-detail-visual-placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2h9l5 5v13a2 2 0 01-2 2H6a2 2 0 01-2-2V4a2 2 0 012-2z"/><path d="M14 2v6h6"/></svg>
            </div>
          {% endif %}
        </div>

        <div class="product-detail-about">
          <span class="product-eyebrow">À propos de ce document</span>
          <h3 class="product-detail-name">{{ product.name }}</h3>
          {% if product.description %}
            <div class="product-detail-description">{{ product.description|raw }}</div>
          {% endif %}
          <p class="product-detail-lede">Traduction assermentée pour vos démarches juridiques, administratives et professionnelles, avec une mise en forme claire et certifiée.</p>

          <ul class="product-detail-features">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
              Traduction certifiée et reconnue
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
              Délai de traitement rapide
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
              Paiement sécurisé via Stripe
            </li>
          </ul>
        </div>
      </div>

      <aside class="product-detail-order" aria-labelledby="order-title">
        <span class="product-eyebrow">Commander</span>
        <h3 id="order-title" class="product-detail-order-title">Configurez votre traduction</h3>
        <p class="product-detail-order-lede">Sélectionnez la langue cible, joignez votre fichier, puis ajoutez au panier.</p>

        <form
          method="post"
          action="{{ path('panier_ajouter', {id: product.id}) }}"
          enctype="multipart/form-data"
          class="product-detail-form"
          id="productOrderForm"
        >
          <div class="product-detail-step">
            <label for="language" class="product-detail-label">
              <span class="product-detail-step-num">1</span>
              Langue cible
            </label>
            <select id="language" name="language" class="product-detail-select" required>
              <option value="">Choisir une langue…</option>
              {% for language in languages %}
                <option value="{{ language }}">{{ language }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="product-detail-step">
            <span class="product-detail-label" id="upload-label">
              <span class="product-detail-step-num">2</span>
              Votre fichier à traduire
            </span>
            <label for="documentFile" class="product-detail-upload" id="uploadZone">
              <input
                type="file"
                id="documentFile"
                name="documentFile"
                class="product-detail-upload-input"
                accept=".pdf,.doc,.docx,.rtf,.txt,.jpg,.jpeg,.png"
                required
                aria-labelledby="upload-label"
              >
              <span class="product-detail-upload-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 16V4m0 0L8 8m4-4l4 4"/><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
              </span>
              <span class="product-detail-upload-title">Glissez votre fichier ici</span>
              <span class="product-detail-upload-hint">ou cliquez pour parcourir</span>
              <span class="product-detail-upload-formats">PDF, Word, RTF, TXT, JPG, PNG — max. 10 Mo</span>
              <span class="product-detail-upload-file is-hidden" id="selectedFileName"></span>
            </label>
          </div>

          <div class="product-detail-price-box" aria-live="polite">
            <div class="product-detail-price-row">
              <span>Tarif estimé</span>
              <strong class="product-detail-price" id="estimatedPrice">
                {% if basePriceCents > 0 %}
                  {{ (basePriceCents / 100)|number_format(2, ',', ' ') }} €
                {% else %}
                  —
                {% endif %}
              </strong>
            </div>
            <p class="product-detail-price-hint" id="priceHint">
              {% if basePriceCents > 0 %}
                Prix de base affiché. Le tarif final dépend de la langue sélectionnée.
              {% else %}
                Sélectionnez une langue pour afficher le tarif.
              {% endif %}
            </p>
          </div>

          <div class="product-detail-actions">
            <button type="submit" class="btn-primary btn-block" id="addToCartBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              Ajouter au panier
            </button>
            <a href="{{ path('panier') }}" class="btn-outline btn-block">Voir le panier</a>
          </div>

          <div class="product-detail-trust">
            <p>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 118 0v4"/></svg>
              Paiement 100 % sécurisé
            </p>
            <p>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M12 3l7 4v6c0 4.5-3 7.5-7 8-4-0.5-7-3.5-7-8V7l7-4z"/><path d="M9 12l2 2 4-4"/></svg>
              Traduction assermentée officielle
            </p>
          </div>
        </form>
      </aside>
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const translationRates = {{ translationRates|json_encode|raw }};
  const basePriceCents = {{ basePriceCents }};
  const languageSelect = document.getElementById('language');
  const priceEl = document.getElementById('estimatedPrice');
  const priceHint = document.getElementById('priceHint');
  const fileInput = document.getElementById('documentFile');
  const uploadZone = document.getElementById('uploadZone');
  const selectedFileName = document.getElementById('selectedFileName');

  if (!languageSelect || !priceEl) {
    return;
  }

  function formatPrice(cents) {
    return (cents / 100).toLocaleString('fr-FR', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }) + ' €';
  }

  function updatePrice() {
    const language = languageSelect.value;
    if (!language) {
      priceEl.textContent = basePriceCents > 0 ? formatPrice(basePriceCents) : '—';
      priceHint.textContent = basePriceCents > 0
        ? 'Prix de base affiché. Le tarif final dépend de la langue sélectionnée.'
        : 'Sélectionnez une langue pour afficher le tarif.';
      return;
    }

    const cents = Object.prototype.hasOwnProperty.call(translationRates, language)
      ? translationRates[language]
      : basePriceCents;

    priceEl.textContent = formatPrice(cents);
    priceHint.textContent = Object.prototype.hasOwnProperty.call(translationRates, language)
      ? 'Tarif spécifique pour ' + language + '.'
      : 'Tarif de base appliqué pour ' + language + '.';
  }

  function showSelectedFile(file) {
    if (!uploadZone || !selectedFileName) {
      return;
    }

    if (!file) {
      selectedFileName.classList.add('is-hidden');
      selectedFileName.textContent = '';
      uploadZone.classList.remove('product-detail-upload--filled');
      return;
    }

    selectedFileName.textContent = file.name;
    selectedFileName.classList.remove('is-hidden');
    uploadZone.classList.add('product-detail-upload--filled');
  }

  languageSelect.addEventListener('change', updatePrice);
  updatePrice();

  if (fileInput) {
    fileInput.addEventListener('change', function () {
      showSelectedFile(fileInput.files[0] || null);
    });
  }

  if (uploadZone) {
    ['dragenter', 'dragover'].forEach(function (eventName) {
      uploadZone.addEventListener(eventName, function (event) {
        event.preventDefault();
        uploadZone.classList.add('product-detail-upload--dragover');
      });
    });

    ['dragleave', 'drop'].forEach(function (eventName) {
      uploadZone.addEventListener(eventName, function (event) {
        event.preventDefault();
        uploadZone.classList.remove('product-detail-upload--dragover');
      });
    });

    uploadZone.addEventListener('drop', function (event) {
      if (!fileInput) {
        return;
      }

      const files = event.dataTransfer.files;
      if (!files.length) {
        return;
      }

      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(files[0]);
      fileInput.files = dataTransfer.files;
      showSelectedFile(files[0]);
    });
  }

  const orderForm = document.getElementById('productOrderForm');
  if (orderForm) {
    orderForm.addEventListener('submit', function () {
      if (typeof gtag === 'function') {
        gtag('event', 'conversion', {'send_to': 'AW-16598173516/8PwjCIvKucMcEMyO0Oo9'});
      }
    });
  }
});
</script>
{% endblock %}
