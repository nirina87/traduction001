{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="main" role="main">
    <section class="section section-no-border pb-0">
        <div class="container py-4 py-lg-5">
            <nav aria-label="Fil d'Ariane" class="mb-4">
                <ol class="breadcrumb product-detail__breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('accueil') }}">Accueil</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ product.name }}</li>
                </ol>
            </nav>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4" role="alert">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4" role="alert">{{ message }}</div>
            {% endfor %}

            <div class="row g-4 g-lg-5 align-items-start">
                <div class="col-lg-6">
                    <div class="product-detail__visual card border-0 shadow-sm rounded-4 overflow-hidden">
                        <img
                            src="{{ asset('uploads/' ~ product.image) }}"
                            class="product-detail__image w-100"
                            alt="{{ product.name }}"
                            loading="lazy"
                        />
                    </div>

                    <div class="mt-4 mt-lg-5">
                        <p class="text-uppercase text-color-primary font-weight-semibold mb-2">À propos de ce document</p>
                        <h1 class="font-weight-bold text-7 text-lg-8 mb-3">{{ product.name }}</h1>
                        <div class="text-4 mb-4 product-detail__description">{{ product.description|raw }}</div>
                        <p class="text-3 text-muted mb-4">Traduction assermentée pour vos démarches juridiques, administratives et professionnelles, avec une mise en forme claire et certifiée.</p>

                        <ul class="product-detail__features list-unstyled mb-0">
                            <li><i class="fas fa-check-circle text-color-primary me-2" aria-hidden="true"></i>Traduction certifiée et reconnue</li>
                            <li><i class="fas fa-check-circle text-color-primary me-2" aria-hidden="true"></i>Délai de traitement rapide</li>
                            <li><i class="fas fa-check-circle text-color-primary me-2" aria-hidden="true"></i>Paiement sécurisé via Stripe</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-6">
                    <aside class="product-detail__order card border-0 shadow-sm rounded-4 p-4 p-lg-5">
                        <p class="text-uppercase text-color-primary font-weight-semibold mb-2">Commander</p>
                        <h2 class="h4 font-weight-bold mb-1">Configurez votre traduction</h2>
                        <p class="text-muted mb-4">Sélectionnez la langue cible, joignez votre fichier, puis ajoutez au panier.</p>

                        <form
                            method="post"
                            action="{{ path('panier_ajouter', {'id': product.id}) }}"
                            enctype="multipart/form-data"
                            class="product-detail__form"
                            id="productOrderForm"
                        >
                            <div class="product-detail__step mb-4">
                                <label for="language" class="form-label product-detail__label">
                                    <span class="product-detail__step-num">1</span>
                                    Langue cible
                                </label>
                                <select id="language" name="language" class="form-select form-select-lg product-detail__select" required>
                                    <option value="">Choisir une langue…</option>
                                    {% for language in languages %}
                                        <option value="{{ language }}">{{ language }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="product-detail__step mb-4">
                                <span class="form-label product-detail__label d-block">
                                    <span class="product-detail__step-num">2</span>
                                    Votre fichier à traduire
                                </span>
                                <label for="documentFile" class="product-detail__upload" id="uploadZone">
                                    <input
                                        type="file"
                                        id="documentFile"
                                        name="documentFile"
                                        class="product-detail__upload-input"
                                        accept=".pdf,.doc,.docx,.rtf,.txt,.jpg,.jpeg,.png"
                                        required
                                    />
                                    <span class="product-detail__upload-icon" aria-hidden="true">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                    </span>
                                    <span class="product-detail__upload-title">Glissez votre fichier ici</span>
                                    <span class="product-detail__upload-hint">ou cliquez pour parcourir</span>
                                    <span class="product-detail__upload-formats">PDF, Word, RTF, TXT, JPG, PNG — max. 10 Mo</span>
                                    <span class="product-detail__upload-file d-none" id="selectedFileName"></span>
                                </label>
                            </div>

                            <div class="product-detail__price-box rounded-4 p-3 mb-4" aria-live="polite">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted">Tarif estimé</span>
                                    <strong class="product-detail__price" id="estimatedPrice">
                                        {% if basePriceCents > 0 %}
                                            {{ (basePriceCents / 100)|number_format(2, ',', ' ') }} €
                                        {% else %}
                                            —
                                        {% endif %}
                                    </strong>
                                </div>
                                <p class="small text-muted mb-0 mt-2" id="priceHint">
                                    {% if basePriceCents > 0 %}
                                        Prix de base affiché. Le tarif final dépend de la langue sélectionnée.
                                    {% else %}
                                        Sélectionnez une langue pour afficher le tarif.
                                    {% endif %}
                                </p>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" id="addToCartBtn">
                                <i class="fas fa-shopping-cart me-2" aria-hidden="true"></i>Ajouter au panier
                            </button>
                            <a href="{{ path('panier') }}" class="btn btn-outline-primary btn-lg w-100">
                                Voir le panier
                            </a>

                            <div class="product-detail__trust mt-4 pt-3 border-top">
                                <p class="small text-muted mb-2"><i class="fas fa-lock me-1" aria-hidden="true"></i>Paiement 100 % sécurisé</p>
                                <p class="small text-muted mb-0"><i class="fas fa-file-signature me-1" aria-hidden="true"></i>Traduction assermentée officielle</p>
                            </div>
                        </form>
                    </aside>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const translationRates = {{ translationRates|json_encode|raw }};
    const basePriceCents = {{ basePriceCents }};
    const languageSelect = document.getElementById('language');
    const priceEl = document.getElementById('estimatedPrice');
    const priceHint = document.getElementById('priceHint');
    const fileInput = document.getElementById('documentFile');
    const uploadZone = document.getElementById('uploadZone');
    const selectedFileName = document.getElementById('selectedFileName');

    function formatPrice(cents) {
        return (cents / 100).toLocaleString('fr-FR', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
        }) + ' €';
    }

    function updatePrice() {
        const language = languageSelect.value;
        if (!language) {
            priceEl.textContent = basePriceCents > 0 ? formatPrice(basePriceCents) : '—';
            priceHint.textContent = basePriceCents > 0
                ? 'Prix de base affiché. Le tarif final dépend de la langue sélectionnée.'
                : 'Sélectionnez une langue pour afficher le tarif.';
            return;
        }

        const cents = Object.prototype.hasOwnProperty.call(translationRates, language)
            ? translationRates[language]
            : basePriceCents;

        priceEl.textContent = formatPrice(cents);
        priceHint.textContent = Object.prototype.hasOwnProperty.call(translationRates, language)
            ? 'Tarif spécifique pour ' + language + '.'
            : 'Tarif de base appliqué pour ' + language + '.';
    }

    function showSelectedFile(file) {
        if (!file) {
            selectedFileName.classList.add('d-none');
            selectedFileName.textContent = '';
            uploadZone.classList.remove('product-detail__upload--filled');
            return;
        }

        selectedFileName.textContent = file.name;
        selectedFileName.classList.remove('d-none');
        uploadZone.classList.add('product-detail__upload--filled');
    }

    languageSelect.addEventListener('change', updatePrice);
    updatePrice();

    fileInput.addEventListener('change', function () {
        showSelectedFile(fileInput.files[0] || null);
    });

    ['dragenter', 'dragover'].forEach(function (eventName) {
        uploadZone.addEventListener(eventName, function (event) {
            event.preventDefault();
            uploadZone.classList.add('product-detail__upload--dragover');
        });
    });

    ['dragleave', 'drop'].forEach(function (eventName) {
        uploadZone.addEventListener(eventName, function (event) {
            event.preventDefault();
            uploadZone.classList.remove('product-detail__upload--dragover');
        });
    });

    uploadZone.addEventListener('drop', function (event) {
        const files = event.dataTransfer.files;
        if (!files.length) {
            return;
        }

        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(files[0]);
        fileInput.files = dataTransfer.files;
        showSelectedFile(files[0]);
    });
});
</script>
{% endblock %}
