{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="main" role="main">
    <section class="section section-no-border pb-0">
        <div class="container py-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-5">
                    <img src="{{ asset('uploads/' ~ product.image) }}" class="img-fluid rounded-4 shadow" alt="{{ product.name }}" style="max-height: 420px; object-fit: cover; width: 100%;" />
                </div>
                <div class="col-lg-7">
                    <p class="text-uppercase text-color-primary font-weight-semibold mb-2">Produit / document</p>
                    <h1 class="font-weight-bold text-8 mb-3">{{ product.name }}</h1>
                    <p class="text-4 mb-4">{{ product.description|raw }}</p>
                    <p class="text-3 text-muted mb-4">Ce document de traduction assermentée est destiné à vos démarches juridiques, administratives et professionnelles avec une mise en forme claire et certifiée.</p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <form method="post" action="{{ path('panier_ajouter', {'id': product.id}) }}" class="d-inline-block">
                            <button type="submit" class="btn btn-primary btn-lg">Ajouter au panier</button>
                        </form>
                        <a href="{{ path('panier') }}" class="btn btn-outline-primary btn-lg">Voir le panier</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
