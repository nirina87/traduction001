{% extends 'base.html.twig' %}

{% block title %} Traductions Légales - Contact {% endblock %}

{% block body %}
<div role="main" class="main">
    <section class="page-header page-header-classic page-header-md">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="text-8 mb-0">Contact</h1>
                    <p class="lead mb-0 text-4">Nous sommes à votre écoute pour vos traductions assermentées et juridiques.</p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <ul class="breadcrumb d-block text-md-end mb-0">
                        <li><a href="{{ path('accueil') }}">Accueil</a></li>
                        <li class="active">Contact</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="row py-4">
            <div class="col-lg-6">
                <h2 class="font-weight-bold text-8 mt-2 mb-0">Contactez-nous !</h2>
                <p class="mb-4">Pour une traduction assermentée et un devis rapide.</p>

                <form class="contact-form" action="php/contact-form.php" method="POST">
                    <div class="contact-form-success alert alert-success d-none mt-4">
                        <strong>Success!</strong> Your message has been sent to us.
                    </div>

                    <div class="contact-form-error alert alert-danger d-none mt-4">
                        <strong>Error!</strong> There was an error sending your message.
                        <span class="mail-error-message text-1 d-block"></span>
                    </div>

                    <div class="row">
                        <div class="form-group col-lg-6">
                            <label class="form-label mb-1 text-2">Nom et prénom</label>
                            <input type="text" value="" data-msg-required="Veuillez saisir votre nom." maxlength="100" class="form-control text-3 h-auto py-2" name="name" required>
                        </div>
                        <div class="form-group col-lg-6">
                            <label class="form-label mb-1 text-2">Adresse email</label>
                            <input type="email" value="" data-msg-required="Veuillez saisir votre adresse email." data-msg-email="Veuillez saisir une adresse email valide." maxlength="100" class="form-control text-3 h-auto py-2" name="email" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col">
                            <label class="form-label mb-1 text-2">Objet</label>
                            <input type="text" value="" data-msg-required="Veuillez saisir l’objet de votre demande." maxlength="100" class="form-control text-3 h-auto py-2" name="subject" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col">
                            <label class="form-label mb-1 text-2">Message</label>
                            <textarea maxlength="5000" data-msg-required="Veuillez saisir votre message." rows="8" class="form-control text-3 h-auto py-2" name="message" required></textarea>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col">
                            <input type="submit" value="Envoyer ma demande" class="btn btn-primary btn-modern" data-loading-text="Envoi...">
                        </div>
                    </div>
                </form>
            </div>

            <div class="col-lg-6">
                <div class="appear-animation" data-appear-animation="fadeIn" data-appear-animation-delay="800">
                    <h4 class="mt-2 mb-1">Notre <strong>bureau</strong></h4>
                    <ul class="list list-icons list-icons-style-2 mt-2">
                        <li><i class="fas fa-map-marker-alt top-6"></i> <strong class="text-dark">Adresse :</strong> Paris, France</li>
                        <li><i class="fas fa-phone top-6"></i> <strong class="text-dark">Téléphone :</strong> +33 1 00 00 00 00</li>
                        <li><i class="fas fa-envelope top-6"></i> <strong class="text-dark">Email :</strong> <a href="mailto:contact@traductionlegales.fr">contact@traductionlegales.fr</a></li>
                    </ul>
                </div>

                <div class="appear-animation" data-appear-animation="fadeIn" data-appear-animation-delay="950">
                    <h4 class="pt-5">Services <strong>de traduction</strong></h4>
                    <ul class="list list-icons list-dark mt-2">
                        <li><i class="far fa-clock top-6"></i> 24h/24 - 7j/7</li>
                        <li><i class="far fa-check-circle top-6"></i> Traductions assermentées certifiées</li>
                        <li><i class="far fa-check-circle top-6"></i> Confidentialité garantie</li>
                    </ul>
                </div>

                <h4 class="pt-5">Prenez <strong>contact</strong></h4>
                <p class="lead mb-0 text-4">Nous vous accompagnons pour vos traductions assermentées, juridiques et administratives avec une réponse rapide et une confidentialité garantie.</p>
            </div>
        </div>
    </div>
</div>

<section class="call-to-action call-to-action-default with-button-arrow content-align-center call-to-action-in-footer">
    <div class="container">
        <div class="row">
            <div class="col-md-9 col-lg-9">
                <div class="call-to-action-content">
                    <h2 class="font-weight-normal text-6 mb-0">Besoin d’une traduction rapide et conforme ?</h2>
                    <p class="mb-0">Nous vous accompagnons pour vos démarches juridiques, administratives et internationales.</p>
                </div>
            </div>
            <div class="col-md-3 col-lg-3">
                <div class="call-to-action-btn">
                    <a href="{{ path('contact') }}" class="btn btn-dark btn-lg text-3 font-weight-semibold px-4 py-3">Demander un devis</a><span class="arrow hlb d-none d-md-block" data-appear-animation="rotateInUpLeft" style="top: -40px; left: 70%;"></span>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}