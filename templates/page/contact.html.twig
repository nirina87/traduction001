{% extends 'base_tl.html.twig' %}

{% set seo_title = "Contact — Demander un Devis de Traduction Assermentée | Traduction Légale" %}
{% set seo_description = "Contactez Traduction Légale, traducteur assermenté inscrit près de la Cour d'Appel. Devis gratuit sous 2h, formulaire sécurisé, e-mail contact@traduction-legale.fr, téléphone 01 87 66 34 33. Paris, France." %}
{% set seo_keywords = "contact traducteur assermenté, devis traduction assermentée, demande devis traduction, traduction-legale.fr contact, traducteur cour d'appel contact, devis traduction juridique, formulaire traduction certifiée, traduction officielle devis gratuit, traducteur assermenté paris" %}
{% set accueil_url = absolute_url(path('accueil')) %}
{% set page_url = absolute_url(path('contact')) %}
{% set og_image = absolute_url(asset('logo-tl.png')) %}

{% block title %}{{ seo_title }}{% endblock %}

{% block meta_description %}{{ seo_description }}{% endblock %}

{% block canonical %}{{ page_url }}{% endblock %}

{% block meta_keywords %}
<meta name="keywords" content="{{ seo_keywords }}">
{% endblock %}

{% block social_meta %}
<meta property="og:locale" content="fr_FR">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Traduction Légale">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ seo_description }}">
<meta property="og:url" content="{{ page_url }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:alt" content="Traduction Légale — Contact et demande de devis de traduction assermentée">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title }}">
<meta name="twitter:description" content="{{ seo_description }}">
<meta name="twitter:image" content="{{ og_image }}">
<meta name="twitter:image:alt" content="Traduction Légale — Contact et demande de devis de traduction assermentée">
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{{ {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': accueil_url ~ '#website',
      'url': accueil_url,
      'name': 'Traduction Légale',
      'description': 'Traducteur assermenté — traduction certifiée de documents officiels',
      'inLanguage': 'fr-FR',
      'publisher': {'@id': accueil_url ~ '#organization'}
    },
    {
      '@type': 'LegalService',
      '@id': accueil_url ~ '#organization',
      'name': 'Traduction Légale — Traducteur Assermenté',
      'url': accueil_url,
      'logo': og_image,
      'image': og_image,
      'description': "Cabinet de traduction assermentée et certifiée de documents officiels, inscrit près d'une Cour d'Appel.",
      'email': 'contact@traduction-legale.fr',
      'telephone': '+33-1-87-66-34-33',
      'priceRange': 'À partir de 28€',
      'areaServed': {
        '@type': 'Country',
        'name': 'France'
      },
      'address': {
        '@type': 'PostalAddress',
        'addressLocality': 'Paris',
        'addressCountry': 'FR'
      },
      'serviceType': 'Traduction assermentée',
      'availableLanguage': ['fr', 'en', 'es', 'de', 'it'],
      'knowsAbout': [
        'Traduction assermentée',
        'Devis traduction officielle',
        'Documents officiels',
        'Traduction juridique',
        'Cour d\'Appel'
      ],
      'contactPoint': {'@id': page_url ~ '#contactpoint'}
    },
    {
      '@type': 'ContactPage',
      '@id': page_url ~ '#webpage',
      'url': page_url,
      'name': seo_title,
      'description': seo_description,
      'isPartOf': {'@id': accueil_url ~ '#website'},
      'about': {'@id': accueil_url ~ '#organization'},
      'mainEntity': {'@id': accueil_url ~ '#organization'},
      'breadcrumb': {'@id': page_url ~ '#breadcrumb'},
      'inLanguage': 'fr-FR',
      'primaryImageOfPage': {
        '@type': 'ImageObject',
        'url': og_image,
        'caption': 'Traduction Légale — contact et demande de devis'
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': page_url ~ '#breadcrumb',
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Accueil',
          'item': accueil_url
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Contact',
          'item': page_url
        }
      ]
    },
    {
      '@type': 'ContactPoint',
      '@id': page_url ~ '#contactpoint',
      'contactType': 'customer service',
      'name': 'Traduction Légale — Service client',
      'url': page_url,
      'telephone': '+33-1-87-66-34-33',
      'email': 'contact@traduction-legale.fr',
      'availableLanguage': ['fr', 'en', 'es', 'de', 'it'],
      'areaServed': {
        '@type': 'Country',
        'name': 'France'
      },
      'hoursAvailable': {
        '@type': 'OpeningHoursSpecification',
        'dayOfWeek': [
          'https://schema.org/Monday',
          'https://schema.org/Tuesday',
          'https://schema.org/Wednesday',
          'https://schema.org/Thursday',
          'https://schema.org/Friday'
        ],
        'opens': '09:00',
        'closes': '18:00'
      }
    },
    {
      '@type': 'ItemList',
      '@id': page_url ~ '#contact-channels',
      'name': 'Coordonnées — Traduction Légale',
      'description': 'Moyens de contact du cabinet de traduction assermentée.',
      'numberOfItems': 4,
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Adresse',
          'description': 'Paris, France'
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Téléphone',
          'description': '01 87 66 34 33'
        },
        {
          '@type': 'ListItem',
          'position': 3,
          'name': 'E-mail',
          'description': 'contact@traduction-legale.fr'
        },
        {
          '@type': 'ListItem',
          'position': 4,
          'name': 'Délai de réponse',
          'description': 'Devis envoyé sous 2h en journée ouvrée'
        }
      ]
    }
  ]
}|json_encode(320)|raw }}
</script>
{% endblock %}

{% block body %}
<div class="page-header" aria-labelledby="page-title">
  <div class="wrap">
    <div>
      <span class="eyebrow" style="color:#D8B774;">Nous écrire</span>
      <h1 id="page-title">Contact</h1>
    </div>
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="{{ path('accueil') }}">Accueil</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Contact</span>
    </nav>
  </div>
</div>

<section class="page-intro" aria-labelledby="contact-intro-title">
  <div class="wrap">
    <h2 id="contact-intro-title">Décrivez votre besoin, nous vous répondons sous 2h ouvrées</h2>
    <p>Indiquez la nature de votre document et la langue souhaitée : un traducteur assermenté étudie votre demande et vous envoie un devis précis, sans engagement de votre part.</p>
  </div>
</section>

<section class="contact-section" aria-labelledby="contact-form-title">
  <div class="wrap">
    <h2 id="contact-form-title" class="visually-hidden">Formulaire de contact et coordonnées</h2>
    <div class="contact-grid">

      <div class="contact-form">
        <form id="contactForm" data-action="{{ path('contact_ajax') }}" novalidate aria-label="Demande de devis de traduction assermentée">
          <div class="form-row-split">
            <div class="form-row">
              <label for="firstName">Prénom</label>
              <input type="text" id="firstName" name="firstName" required placeholder="Votre prénom" autocomplete="given-name">
            </div>
            <div class="form-row">
              <label for="lastName">Nom</label>
              <input type="text" id="lastName" name="lastName" required placeholder="Votre nom" autocomplete="family-name">
            </div>
          </div>

          <div class="form-row">
            <label for="email">Adresse e-mail</label>
            <input type="email" id="email" name="email" required placeholder="votre@email.fr" autocomplete="email">
          </div>

          <div class="form-row">
            <label for="phone">Téléphone (facultatif)</label>
            <input type="tel" id="phone" name="phone" placeholder="06 12 34 56 78" autocomplete="tel">
          </div>

          <div class="form-row-split">
            <div class="form-row">
              <label for="docType">Type de document</label>
              <select id="docType" name="docType">
                <option value="">Sélectionnez...</option>
                <option>Acte d'état civil</option>
                <option>Diplôme / relevé de notes</option>
                <option>Jugement / décision de justice</option>
                <option>Contrat / acte notarié</option>
                <option>Casier judiciaire</option>
                <option>Pièce d'identité</option>
                <option>Autre document</option>
              </select>
            </div>
            <div class="form-row">
              <label for="lang">Langue souhaitée</label>
              <input type="text" id="lang" name="lang" placeholder="Ex. Anglais → Français">
            </div>
          </div>

          <div class="form-row">
            <label for="message">Votre message</label>
            <textarea id="message" name="message" placeholder="Décrivez votre document et votre délai souhaité..."></textarea>
          </div>

          <button type="submit" class="form-submit">Envoyer ma demande</button>
        </form>

        <div class="form-error" id="formError" role="alert">
          <p>Une erreur est survenue lors de l'envoi. Veuillez réessayer ou nous contacter directement par e-mail.</p>
        </div>

        <div class="form-success" id="formSuccess">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
          <h3>Votre demande a bien été envoyée</h3>
          <p>Un traducteur assermenté vous répond par e-mail dans les 2 heures ouvrées qui suivent.</p>
        </div>
      </div>

      <aside aria-labelledby="contact-info-title">
        <h2 id="contact-info-title" class="visually-hidden">Coordonnées du cabinet</h2>
        <div class="contact-info-item">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3>Adresse</h3>
            <p>Paris, France</p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <h3>Téléphone</h3>
            <p><a href="tel:+33187663433">01 87 66 34 33</a></p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
          </div>
          <div>
            <h3>E-mail</h3>
            <p><a href="mailto:contact@traduction-legale.fr">contact@traduction-legale.fr</a></p>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          </div>
          <div>
            <h3>Délai de réponse</h3>
            <p>Devis envoyé sous 2h en journée ouvrée</p>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>
{% endblock %}
