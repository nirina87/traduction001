{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
<div class="main" role="main">
    <section class="section section-no-border pb-0">
        <div class="container py-5">
            <div class="row align-items-end justify-content-between mb-4">
                <div class="col-lg-8">
                    <p class="text-uppercase text-color-primary font-weight-semibold mb-2">Panier</p>
                    <h1 class="font-weight-bold text-8 mb-2">Votre sélection de documents</h1>
                    <p class="text-3 mb-0">Les documents ajoutés au panier sont conservés pendant votre session.</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <a href="{{ path('accueil') }}" class="btn btn-outline-primary">Retour à l’accueil</a>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success mb-4">{{ message }}</div>
            {% endfor %}

            {% if cart is empty %}
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <p class="mb-0 text-muted">Votre panier est actuellement vide. Ajoutez un document depuis la page d’accueil ou la page détail.</p>
                </div>
            {% else %}
                <div class="row g-4">
                    {% for item in cart %}
                        <div class="col-md-6 col-xl-4">
                            <article class="card border-0 shadow-sm rounded-4 p-3 h-100">
                                <img src="{{ asset(products[item.id].image) }}" class="img-fluid rounded-3 mb-3" alt="{{ item.title }}" style="height: 110px; object-fit: cover; width: 100%;" />
                                <h3 class="text-4 mb-2">{{ item.title }}</h3>
                                <p class="text-muted mb-3">{{ item.description }}</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-primary text-light">Quantité : {{ item.quantity }}</span>
                                    <a href="{{ path('produit_detail', {'id': item.id}) }}" class="btn btn-outline-primary btn-sm">Détail</a>
                                </div>
                            </article>
                        </div>
                    {% endfor %}
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a href="{{ path('commande') }}" class="btn btn-primary btn-lg">Passer la commande</a>
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
