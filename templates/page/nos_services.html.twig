{% extends 'base_tl.html.twig' %}

{% set seo_title = "Services & Tarifs — Traduction Assermentée par Document | Traduction Légale" %}
{% set seo_description = "Catalogue de traductions assermentées : état civil, diplômes, jugements, contrats et pièces d'identité. Tarif transparent dès 28€/page, devis sous 2h, traducteur inscrit près de la Cour d'Appel." %}
{% set seo_keywords = "traduction assermentée, services traduction, tarifs traduction juridique, traducteur cour d'appel, catalogue traduction officielle, traduction acte naissance, traduction diplôme, traduction jugement, prix traduction assermentée, commande traduction en ligne, traduction document officiel" %}
{% set accueil_url = absolute_url(path('accueil')) %}
{% set page_url = absolute_url(path('services')) %}
{% set og_image = absolute_url(asset('logo-tl.png')) %}

{% block title %}{{ seo_title }}{% endblock %}

{% block meta_description %}{{ seo_description }}{% endblock %}

{% block canonical %}{{ page_url }}{% endblock %}

{% block meta_keywords %}
<meta name="keywords" content="{{ seo_keywords }}">
{% endblock %}

{% block social_meta %}
<meta property="og:locale" content="fr_FR">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Traduction Légale">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ seo_description }}">
<meta property="og:url" content="{{ page_url }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:alt" content="Traduction Légale — Catalogue des services de traduction assermentée">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title }}">
<meta name="twitter:description" content="{{ seo_description }}">
<meta name="twitter:image" content="{{ og_image }}">
<meta name="twitter:image:alt" content="Traduction Légale — Catalogue des services de traduction assermentée">
{% endblock %}

{% block structured_data %}
{% set document_items = [] %}
{% set catalog_offers = [] %}
{% for product in products|filter(product => product.active) %}
  {% set detail_url = absolute_url(path('produit_detail', {id: product.id})) %}
  {% set document_items = document_items|merge([{
    '@type': 'ListItem',
    'position': loop.index,
    'name': product.name,
    'url': detail_url
  }]) %}
  {% set catalog_offers = catalog_offers|merge([{
    '@type': 'Offer',
    'name': 'Traduction assermentée — ' ~ product.name,
    'url': detail_url,
    'priceCurrency': 'EUR',
    'price': product.basePrice ?? 28,
    'availability': 'https://schema.org/InStock',
    'itemOffered': {
      '@type': 'Service',
      'name': product.name,
      'serviceType': product.category|default('Traduction assermentée'),
      'url': detail_url,
      'provider': {'@id': accueil_url ~ '#organization'}
    }
  }]) %}
{% endfor %}
<script type="application/ld+json">
{{ {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': accueil_url ~ '#website',
      'url': accueil_url,
      'name': 'Traduction Légale',
      'inLanguage': 'fr-FR',
      'publisher': {'@id': accueil_url ~ '#organization'}
    },
    {
      '@type': 'LegalService',
      '@id': accueil_url ~ '#organization',
      'name': 'Traduction Légale — Traducteur Assermenté',
      'url': accueil_url,
      'logo': og_image,
      'image': og_image,
      'description': "Service de traduction assermentée et certifiée de documents officiels, inscrit près d'une Cour d'Appel.",
      'email': 'contact@traductions-legales.fr',
      'priceRange': 'À partir de 28€',
      'areaServed': {
        '@type': 'Country',
        'name': 'France'
      },
      'serviceType': 'Traduction assermentée',
      'availableLanguage': ['fr', 'en', 'es', 'de', 'it']
    },
    {
      '@type': 'WebPage',
      '@id': page_url ~ '#webpage',
      'url': page_url,
      'name': seo_title,
      'description': seo_description,
      'isPartOf': {'@id': accueil_url ~ '#website'},
      'about': {'@id': accueil_url ~ '#organization'},
      'breadcrumb': {'@id': page_url ~ '#breadcrumb'},
      'inLanguage': 'fr-FR',
      'primaryImageOfPage': {
        '@type': 'ImageObject',
        'url': og_image
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': page_url ~ '#breadcrumb',
      'itemListElement': [
        {
          '@type': 'ListItem',
          'position': 1,
          'name': 'Accueil',
          'item': accueil_url
        },
        {
          '@type': 'ListItem',
          'position': 2,
          'name': 'Services',
          'item': page_url
        }
      ]
    },
    {
      '@type': 'CollectionPage',
      '@id': page_url ~ '#catalog',
      'name': 'Catalogue des traductions assermentées',
      'description': seo_description,
      'url': page_url,
      'isPartOf': {'@id': page_url ~ '#webpage'},
      'mainEntity': {
        '@type': 'ItemList',
        'name': 'Documents à traduire',
        'numberOfItems': document_items|length,
        'itemListElement': document_items
      }
    },
    {
      '@type': 'OfferCatalog',
      'name': 'Tarifs des traductions assermentées',
      'url': page_url,
      'itemListElement': catalog_offers
    }
  ]
}|json_encode(320)|raw }}
</script>
{% endblock %}

{% block body %}

<div class="page-header" aria-labelledby="page-title">
  <div class="wrap">
    <div>
      <span class="eyebrow">Catalogue des prestations</span>
      <h1 id="page-title">Services &amp; tarifs</h1>
    </div>
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="{{ path('accueil') }}">Accueil</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Services</span>
    </nav>
  </div>
</div>

<section class="page-intro" aria-labelledby="services-intro-title">
  <div class="wrap">
    <h2 id="services-intro-title">Une traduction certifiée pour chaque type de document officiel</h2>
    <p>Sélectionnez votre document, consultez le détail de la prestation et lancez votre commande. Chaque traduction est réalisée par un traducteur assermenté inscrit près d'une Cour d'Appel et porte cachet, signature et numéro de répertoire.</p>
  </div>
</section>

<section class="catalog" id="catalogue" aria-labelledby="catalog-title">
  <div class="wrap">
    <h2 id="catalog-title" class="visually-hidden">Catalogue des documents à traduire</h2>
    <div class="catalog-grid" role="list">
      {% set activeProducts = products|filter(product => product.active) %}
      {% for product in activeProducts %}
        <article class="product-card" role="listitem">
          <div class="product-thumb">
            {% if product.image %}
              <img src="{{ asset('uploads/' ~ product.image) }}"
                   alt="Traduction assermentée — {{ product.name }}"
                   loading="lazy"
                   width="360"
                   height="128">
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 2h9l5 5v13a2 2 0 01-2 2H6a2 2 0 01-2-2V4a2 2 0 012-2z"/><path d="M14 2v6h6"/></svg>
            {% endif %}
          </div>
          <div class="product-body">
            {% if product.category %}
              <span class="product-eyebrow">{{ product.category }}</span>
            {% endif %}
            <h3>{{ product.name }}</h3>
            {% if product.basePrice %}
              <div class="product-price">À partir de {{ product.basePrice }}€ / page</div>
            {% endif %}
            <div class="product-actions">
              <a href="{{ path('produit_detail', {'id': product.id}) }}"
                 class="btn-outline"
                 aria-label="Voir le détail de la traduction assermentée : {{ product.name }}">Voir le détail</a>
              <a href="{{ path('produit_detail', {'id': product.id}) }}"
                 class="btn-outline btn-add"
                 aria-label="Commander la traduction assermentée : {{ product.name }}">Commander</a>
            </div>
          </div>
        </article>
      {% else %}
        <p>Aucun document n'est disponible pour le moment.</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="dossier" aria-labelledby="services-highlights-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Ce qui accompagne chaque commande</span>
      <h2 id="services-highlights-title">Un service pensé pour la rigueur des démarches officielles</h2>
    </div>
    <div class="timeline">
      <div class="tl-step">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 110 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </div>
        <span class="tl-tag">Accompagnement</span>
        <h3>Conseil personnalisé</h3>
        <p>Nous vous indiquons le format de traduction le plus adapté à votre démarche, avant toute commande.</p>
      </div>
      <div class="tl-step">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </div>
        <span class="tl-tag">Réactivité</span>
        <h3>Devis sous 2h ouvrées</h3>
        <p>Chaque demande est prise en charge rapidement, avec un délai annoncé avant tout engagement.</p>
      </div>
      <div class="tl-step">
        <div class="tl-dot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <span class="tl-tag">Confidentialité</span>
        <h3>Données protégées</h3>
        <p>Vos documents sont traités avec discrétion, dans le respect de vos démarches personnelles ou professionnelles.</p>
      </div>
    </div>
  </div>
</section>

<section class="pricing" id="tarifs" aria-labelledby="services-pricing-note-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Bon à savoir</span>
      <h2 id="services-pricing-note-title">Le tarif affiché est une base, votre devis est toujours confirmé</h2>
    </div>
    <p class="price-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
      Le tarif de 28€ par page s'applique aux documents standards en anglais, espagnol, italien ou allemand. Les langues rares, les documents longs ou les mentions manuscrites peuvent faire varier le prix final — toujours communiqué avant validation de votre commande.
    </p>
  </div>
</section>

{% endblock %}
