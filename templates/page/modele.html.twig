<style>
  :root{
    --ink:#0a2047;
    --ink-soft:#3d3d3d;
    --paper:#fdfdfd;
    --paper-deep:rgba(61,61,61,0.06);
    --seal:#0a2047;
    --seal-deep:#3d3d3d;
    --pine:#3d3d3d;
    --redseal:#0a2047;
    --line: rgba(10,32,71,0.14);
    --serif: 'Fraunces', serif;
    --sans: 'Inter', sans-serif;
    --mono: 'JetBrains Mono', monospace;
    --maxw: 1140px;
  }

  *{margin:0;padding:0;box-sizing:border-box;}

  html{scroll-behavior:smooth;}

  body{
    background:var(--paper);
    color:var(--ink);
    font-family:var(--sans);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  a{color:inherit;text-decoration:none;}

  img,svg{display:block;max-width:100%;}

  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 32px;}

  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important;}
  }

  /* ===== texture de fond papier ===== */
  body{
    background-image:
      radial-gradient(circle at 18% 30%, rgba(10,32,71,0.04), transparent 45%),
      radial-gradient(circle at 82% 70%, rgba(61,61,61,0.04), transparent 50%);
  }

  /* ===== topbar ===== */
  .topbar{
    border-bottom:1px solid var(--line);
    background:rgba(253,253,253,0.92);
    backdrop-filter: blur(6px);
    position:sticky;
    top:0;
    z-index:50;
  }
  .topbar .wrap{
    display:flex;
    align-items:center;
    justify-content:space-between;
    min-height:104px;
    padding:12px 32px;
  }
  .brand{
    display:flex;
    align-items:center;
    flex-shrink:0;
  }
  .brand img{
    height:88px;
    width:auto;
    display:block;
  }
  nav{display:flex;gap:30px;align-items:center;}
  nav a{
    font-size:0.92rem;
    font-weight:500;
    color:var(--ink-soft);
    transition:color .2s;
  }
  nav a:hover{color:var(--seal-deep);}
  .nav-cta{
    background:var(--ink);
    color:var(--paper);
    padding:10px 20px;
    border-radius:3px;
    font-weight:600;
    font-size:0.88rem;
    transition:background .2s;
  }
  .nav-cta:hover{background:var(--seal-deep);}
  .nav-toggle{display:none;}

  /* ===== HERO ===== */
  .hero{
    position:relative;
    padding:88px 0 70px;
    border-bottom:1px solid var(--line);
    overflow:hidden;
  }
  .hero .wrap{
    display:grid;
    grid-template-columns:1.15fr 0.85fr;
    gap:56px;
    align-items:center;
  }
  .eyebrow{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:var(--mono);
    font-size:0.72rem;
    letter-spacing:0.09em;
    text-transform:uppercase;
    color:var(--pine);
    margin-bottom:22px;
  }
  .eyebrow::before{
    content:'';
    width:7px;height:7px;
    border-radius:50%;
    background:var(--pine);
    display:inline-block;
  }
  h1{
    font-family:var(--serif);
    font-weight:600;
    font-size:clamp(2.3rem, 4vw, 3.4rem);
    line-height:1.08;
    letter-spacing:-0.01em;
    margin-bottom:24px;
  }
  h1 em{
    font-style:italic;
    font-weight:500;
    color:var(--seal-deep);
  }
  .hero-lede{
    font-size:1.1rem;
    color:var(--ink-soft);
    max-width:480px;
    margin-bottom:36px;
  }
  .hero-actions{
    display:flex;
    gap:16px;
    align-items:center;
    flex-wrap:wrap;
    margin-bottom:40px;
  }
  .btn-primary{
    background:var(--ink);
    color:var(--paper);
    padding:16px 28px;
    border-radius:3px;
    font-weight:600;
    font-size:0.95rem;
    border:none;
    cursor:pointer;
    transition:background .2s, transform .15s;
    display:inline-flex;
    align-items:center;
    gap:10px;
  }
  .btn-primary:hover{background:var(--seal-deep);transform:translateY(-1px);}
  .btn-secondary{
    color:var(--ink);
    font-weight:600;
    font-size:0.95rem;
    border-bottom:1.5px solid var(--ink);
    padding-bottom:2px;
    transition:border-color .2s, color .2s;
  }
  .btn-secondary:hover{color:var(--seal-deep);border-color:var(--seal-deep);}

  .hero-proof{
    display:flex;
    gap:28px;
    flex-wrap:wrap;
  }
  .hero-proof .item{
    font-family:var(--mono);
    font-size:0.78rem;
    color:var(--ink-soft);
  }
  .hero-proof .item b{
    display:block;
    font-family:var(--serif);
    font-size:1.5rem;
    color:var(--ink);
    font-weight:600;
  }

  /* ===== le sceau (signature element) ===== */
  .seal-wrap{
    display:flex;
    justify-content:center;
    align-items:center;
    position:relative;
  }
  .seal{
    width:320px;
    height:320px;
    position:relative;
  }
  .seal svg{
    width:100%;
    height:100%;
    animation: stamp-in 0.9s cubic-bezier(.2,.9,.25,1) both;
    transform-origin:center;
  }
  @keyframes stamp-in{
    0%{ transform:scale(1.4) rotate(-8deg); opacity:0; }
    55%{ transform:scale(0.96) rotate(1deg); opacity:1; }
    75%{ transform:scale(1.03) rotate(-0.5deg); }
    100%{ transform:scale(1) rotate(0deg); opacity:1; }
  }
  @media (prefers-reduced-motion: reduce){
    .seal svg{animation:none;}
  }

  /* ===== bande de confiance ===== */
  .trustbar{
    border-bottom:1px solid var(--line);
    background:var(--paper-deep);
  }
  .trustbar .wrap{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 32px;
    gap:24px;
    flex-wrap:wrap;
  }
  .trust-item{
    display:flex;
    align-items:center;
    gap:10px;
    font-size:0.85rem;
    color:var(--ink-soft);
    font-weight:500;
  }
  .trust-item svg{width:18px;height:18px;flex-shrink:0;color:var(--pine);}

  /* ===== sections génériques ===== */
  section{padding:96px 0;}
  .section-head{
    max-width:640px;
    margin-bottom:56px;
  }
  .section-head .eyebrow{color:var(--seal-deep);}
  h2{
    font-family:var(--serif);
    font-weight:600;
    font-size:clamp(1.8rem, 2.6vw, 2.5rem);
    letter-spacing:-0.01em;
    line-height:1.15;
  }
  .section-head p{
    margin-top:16px;
    color:var(--ink-soft);
    font-size:1.05rem;
  }

  /* ===== parcours du dossier ===== */
  .dossier{
    background:var(--ink);
    color:var(--paper);
  }
  .dossier .section-head h2{color:var(--paper);}
  .dossier .section-head p{color:rgba(253,253,253,0.7);}
  .dossier .eyebrow{color:#fdfdfd;}
  .dossier .eyebrow::before{background:#fdfdfd;}

  .timeline{
    position:relative;
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:0;
  }
  .timeline::before{
    content:'';
    position:absolute;
    top:30px;
    left:0;
    right:0;
    height:1px;
    background:rgba(253,253,253,0.18);
  }
  .tl-step{
    position:relative;
    padding-right:24px;
  }
  .tl-dot{
    width:60px;height:60px;
    border-radius:50%;
    border:1.5px solid rgba(253,253,253,0.45);
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom:28px;
    background:var(--ink);
    position:relative;
    z-index:2;
  }
  .tl-dot svg{width:26px;height:26px;color:#fdfdfd;}
  .tl-step h3{
    font-family:var(--serif);
    font-weight:600;
    font-size:1.18rem;
    margin-bottom:10px;
  }
  .tl-step p{
    font-size:0.92rem;
    color:rgba(253,253,253,0.65);
    line-height:1.55;
  }
  .tl-tag{
    font-family:var(--mono);
    font-size:0.68rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:rgba(253,253,253,0.8);
    margin-bottom:10px;
    display:block;
  }

  /* ===== documents pris en charge ===== */
  .docs-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .doc-card{
    background:var(--paper);
    padding:32px;
    transition:background .2s;
  }
  .doc-card:hover{background:var(--paper-deep);}
  .doc-card svg{width:28px;height:28px;color:var(--seal-deep);margin-bottom:18px;}
  .doc-card h3{
    font-family:var(--serif);
    font-size:1.08rem;
    font-weight:600;
    margin-bottom:8px;
  }
  .doc-card p{
    font-size:0.88rem;
    color:var(--ink-soft);
  }

  /* ===== tarifs ===== */
  .pricing{
    background:var(--paper-deep);
  }
  .price-table{
    display:grid;
    grid-template-columns:1.3fr 0.7fr;
    border:1px solid var(--line);
    background:var(--paper);
  }
  .price-row{
    display:grid;
    grid-template-columns:1.3fr 0.7fr;
    grid-column:1 / -1;
    border-bottom:1px solid var(--line);
  }
  .price-row:last-child{border-bottom:none;}
  .price-row.head{
    background:var(--ink);
    color:var(--paper);
    font-family:var(--mono);
    font-size:0.72rem;
    text-transform:uppercase;
    letter-spacing:0.07em;
  }
  .price-row .cell{
    padding:20px 28px;
    display:flex;
    align-items:center;
  }
  .price-row:not(.head) .cell:first-child{
    font-weight:600;
    font-size:1rem;
  }
  .price-row:not(.head) .cell + .cell{
    font-family:var(--mono);
    font-size:1.1rem;
    color:var(--seal-deep);
    font-weight:500;
    border-left:1px solid var(--line);
  }
  .price-row.featured{
    background:rgba(10,32,71,0.06);
  }
  .price-note{
    margin-top:20px;
    font-size:0.85rem;
    color:var(--ink-soft);
    display:flex;
    align-items:flex-start;
    gap:10px;
  }
  .price-note svg{width:16px;height:16px;flex-shrink:0;margin-top:2px;color:var(--pine);}

  /* ===== pourquoi nous ===== */
  .why-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:48px;
  }
  .why-item{
    display:flex;
    gap:20px;
  }
  .why-num{
    font-family:var(--mono);
    font-size:0.78rem;
    color:var(--seal-deep);
    border:1px solid var(--seal-deep);
    border-radius:50%;
    width:30px;height:30px;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-shrink:0;
    margin-top:2px;
  }
  .why-item h3{
    font-family:var(--serif);
    font-size:1.15rem;
    font-weight:600;
    margin-bottom:8px;
  }
  .why-item p{
    font-size:0.92rem;
    color:var(--ink-soft);
  }

  /* ===== FAQ ===== */
  .faq-list{
    border-top:1px solid var(--line);
  }
  .faq-item{
    border-bottom:1px solid var(--line);
  }
  .faq-q{
    padding:24px 0;
    display:flex;
    justify-content:space-between;
    align-items:center;
    cursor:pointer;
    font-family:var(--serif);
    font-weight:600;
    font-size:1.08rem;
    gap:20px;
  }
  .faq-q .plus{
    font-family:var(--mono);
    font-size:1.3rem;
    color:var(--seal-deep);
    flex-shrink:0;
    transition:transform .25s;
  }
  .faq-item[open] .plus{transform:rotate(45deg);}
  .faq-a{
    padding-bottom:24px;
    color:var(--ink-soft);
    font-size:0.95rem;
    max-width:680px;
  }
  details summary::-webkit-details-marker{display:none;}
  details summary{list-style:none;}

  /* ===== CTA final ===== */
  .cta-final{
    background:var(--ink);
    color:var(--paper);
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .cta-final::before{
    content:'';
    position:absolute;
    width:600px;height:600px;
    border-radius:50%;
    border:1px solid rgba(253,253,253,0.12);
    top:-300px;left:50%;
    transform:translateX(-50%);
  }
  .cta-final .wrap{position:relative;z-index:2;}
  .cta-final h2{color:var(--paper);max-width:560px;margin:0 auto 20px;}
  .cta-final p{
    color:rgba(253,253,253,0.7);
    max-width:480px;
    margin:0 auto 36px;
  }
  .cta-final-form{
    display:flex;
    gap:0;
    max-width:480px;
    margin:0 auto;
    border:1px solid rgba(253,253,253,0.3);
    border-radius:3px;
    overflow:hidden;
  }
  .cta-final-form input{
    flex:1;
    background:transparent;
    border:none;
    padding:16px 18px;
    color:var(--paper);
    font-size:0.95rem;
    font-family:var(--sans);
  }
  .cta-final-form input::placeholder{color:rgba(253,253,253,0.45);}
  .cta-final-form input:focus{outline:none;}
  .cta-final-form button{
    background:#fdfdfd;
    color:var(--ink);
    border:none;
    padding:0 26px;
    font-weight:600;
    font-size:0.92rem;
    cursor:pointer;
    transition:background .2s;
  }
  .cta-final-form button:hover{background:rgba(253,253,253,0.85);}

  /* ===== footer ===== */
  footer{
    border-top:1px solid var(--line);
    padding:56px 0 32px;
  }
  .footer-grid{
    display:grid;
    grid-template-columns:1.4fr 0.8fr 0.8fr 0.8fr;
    gap:40px;
    margin-bottom:40px;
  }
  .footer-brand{
    font-family:var(--serif);
    font-weight:600;
    font-size:1.1rem;
    margin-bottom:14px;
  }
  .footer-grid p{
    font-size:0.88rem;
    color:var(--ink-soft);
    max-width:280px;
  }
  .footer-col h4{
    font-family:var(--mono);
    font-size:0.72rem;
    text-transform:uppercase;
    letter-spacing:0.07em;
    color:var(--ink-soft);
    margin-bottom:16px;
  }
  .footer-col a{
    display:block;
    font-size:0.9rem;
    margin-bottom:10px;
    color:var(--ink);
    transition:color .2s;
  }
  .footer-col a:hover{color:var(--seal-deep);}
  .footer-bottom{
    border-top:1px solid var(--line);
    padding-top:24px;
    display:flex;
    justify-content:space-between;
    font-size:0.8rem;
    color:var(--ink-soft);
    flex-wrap:wrap;
    gap:10px;
  }

  /* ===== focus visible ===== */
  a:focus-visible, button:focus-visible, summary:focus-visible, input:focus-visible{
    outline:2px solid var(--seal-deep);
    outline-offset:3px;
  }

  /* ===== responsive ===== */
  @media (max-width:980px){
    .hero .wrap{grid-template-columns:1fr;gap:48px;}
    .seal{width:240px;height:240px;}
    .seal-wrap{order:-1;}
    .timeline{grid-template-columns:1fr 1fr;row-gap:48px;}
    .timeline::before{display:none;}
    .docs-grid{grid-template-columns:1fr 1fr;}
    .why-grid{grid-template-columns:1fr;}
    nav{display:none;}
    .footer-grid{grid-template-columns:1fr 1fr;}
  }
  @media (max-width:640px){
    .wrap{padding:0 20px;}
    .topbar .wrap{min-height:88px;padding:10px 20px;}
    .brand img{height:72px;}
    section{padding:64px 0;}
    .timeline{grid-template-columns:1fr;}
    .docs-grid{grid-template-columns:1fr;}
    .price-row, .price-row.head{grid-template-columns:1fr;}
    .price-row .cell + .cell{border-left:none;border-top:1px solid var(--line);}
    .trustbar .wrap{flex-direction:column;align-items:flex-start;gap:14px;}
    .cta-final-form{flex-direction:column;border:none;gap:10px;}
    .cta-final-form input{border:1px solid rgba(253,253,253,0.3);border-radius:3px;}
    .cta-final-form button{padding:14px;border-radius:3px;}
    .footer-grid{grid-template-columns:1fr;gap:32px;}
    .hero{padding:56px 0 48px;}
  }
</style>
</head>
<body>

<header class="topbar">
  <div class="wrap">
    <a href="#top" class="brand">
      <img src="{{ asset('logo-tl.png') }}" alt="Traductions Légales — Traductions assermentées">
    </a>
    <nav>
      <a href="#documents">Documents</a>
      <a href="#parcours">Le parcours</a>
      <a href="#tarifs">Tarifs</a>
      <a href="#faq">FAQ</a>
      <a href="#contact" class="nav-cta">Demander un devis</a>
    </nav>
  </div>
</header>

<main id="top">

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap">
      <div>
        <span class="eyebrow">Traducteur assermenté · inscrit près d'une Cour d'Appel</span>
        <h1>Votre document a force légale.<br>Sa traduction <em>aussi</em>.</h1>
        <p class="hero-lede">
          Traduction certifiée de vos actes officiels — état civil, diplômes, jugements, contrats — reconnue par les administrations, ambassades et tribunaux français et étrangers.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn-primary">
            Demander un devis gratuit
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#tarifs" class="btn-secondary">Voir les tarifs</a>
        </div>
        <div class="hero-proof">
          <div class="item"><b>28€</b>à partir de / page traduite</div>
          <div class="item"><b>24–48h</b>délai moyen de livraison</div>
          <div class="item"><b>100%</b>traductions certifiées conformes</div>
        </div>
      </div>

      <div class="seal-wrap">
        <div class="seal">
          <svg viewBox="0 0 300 300" fill="none">
            <defs>
              <path id="circlePath" d="M 150, 150 m -118, 0 a 118,118 0 1,1 236,0 a 118,118 0 1,1 -236,0" />
            </defs>
            <circle cx="150" cy="150" r="135" stroke="#3d3d3d" stroke-width="1.2" opacity="0.5"/>
            <circle cx="150" cy="150" r="118" stroke="#0a2047" stroke-width="1.5"/>
            <circle cx="150" cy="150" r="92" stroke="#0a2047" stroke-width="1"/>
            <text font-family="JetBrains Mono" font-size="11.5" letter-spacing="3" fill="#0a2047">
              <textPath href="#circlePath" startOffset="2%">
                TRADUCTEUR · ASSERMENTÉ · COUR D'APPEL ·
              </textPath>
            </text>
            <g font-family="Fraunces" fill="#0a2047" text-anchor="middle">
              <text x="150" y="138" font-size="20" font-weight="600">CERTIFIÉ</text>
              <text x="150" y="166" font-size="13" letter-spacing="1" fill="#3d3d3d">CONFORME&nbsp;À&nbsp;L'ORIGINAL</text>
            </g>
            <line x1="110" y1="184" x2="190" y2="184" stroke="#3d3d3d" stroke-width="1" opacity="0.7"/>
            <text x="150" y="200" font-family="JetBrains Mono" font-size="9" fill="#3d3d3d" text-anchor="middle" letter-spacing="1" opacity="0.85">N° DE RÉPERTOIRE — SCEAU OFFICIEL</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRUSTBAR ============ -->
  <div class="trustbar">
    <div class="wrap">
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 12l2 2 4-4M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
        Accepté par préfectures, mairies &amp; ambassades
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 7l9-4 9 4-9 4-9-4zm0 0v10l9 4 9-4V7"/></svg>
        Cachet, signature et numéro de répertoire
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        Devis sous 2h ouvrées
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 8l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z"/></svg>
        Envoi numérique + original par courrier
      </div>
    </div>
  </div>

  <!-- ============ DOCUMENTS ============ -->
  <section id="documents">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Documents pris en charge</span>
        <h2>Chaque pièce traduite avec la rigueur qu'elle exige</h2>
        <p>Du simple extrait d'acte au jugement complexe, chaque traduction est relue terme à terme avant d'être certifiée conforme.</p>
      </div>

      <div class="docs-grid">
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2h9l5 5v13a2 2 0 01-2 2H6a2 2 0 01-2-2V4a2 2 0 012-2z"/><path d="M14 2v6h6"/></svg>
          <h3>État civil</h3>
          <p>Actes de naissance, mariage, décès, livrets de famille.</p>
        </div>
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
          <h3>Diplômes &amp; relevés</h3>
          <p>Diplômes, bulletins, relevés de notes pour études ou équivalence.</p>
        </div>
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="16" rx="1"/><path d="M8 9h8M8 13h8M8 17h4"/></svg>
          <h3>Jugements &amp; décisions</h3>
          <p>Divorces, successions, décisions de justice françaises et étrangères.</p>
        </div>
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 12l2 2 4-4M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
          <h3>Casiers judiciaires</h3>
          <p>Extraits B3, certificats de non-condamnation, attestations.</p>
        </div>
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 4h16v16H4z"/><path d="M9 9h6v6H9z"/></svg>
          <h3>Contrats &amp; statuts</h3>
          <p>Contrats commerciaux, statuts de société, actes notariés.</p>
        </div>
        <div class="doc-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 21v-2a6 6 0 0112 0v2"/></svg>
          <h3>Permis &amp; pièces d'identité</h3>
          <p>Permis de conduire, cartes grises, passeports, titres de séjour.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PARCOURS DU DOSSIER ============ -->
  <section class="dossier" id="parcours">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Le parcours de votre dossier</span>
        <h2>De l'envoi du document au sceau officiel</h2>
        <p>Quatre étapes, aucune surprise. Vous savez à chaque instant où en est votre dossier.</p>
      </div>

      <div class="timeline">
        <div class="tl-step">
          <div class="tl-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 15a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v7a2 2 0 01-2 2z"/></svg>
          </div>
          <span class="tl-tag">Étape 1</span>
          <h3>Document reçu</h3>
          <p>Vous envoyez une photo ou un scan de votre document via le formulaire. Aucun déplacement n'est nécessaire à ce stade.</p>
        </div>
        <div class="tl-step">
          <div class="tl-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 013 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
          </div>
          <span class="tl-tag">Étape 2</span>
          <h3>Traduction certifiée</h3>
          <p>Le document est traduit intégralement, terme juridique par terme juridique, puis relu une seconde fois.</p>
        </div>
        <div class="tl-step">
          <div class="tl-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <span class="tl-tag">Étape 3</span>
          <h3>Cachet apposé</h3>
          <p>Signature, cachet et numéro de répertoire sont apposés : le document devient juridiquement opposable.</p>
        </div>
        <div class="tl-step">
          <div class="tl-dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 8l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z"/></svg>
          </div>
          <span class="tl-tag">Étape 4</span>
          <h3>Document délivré</h3>
          <p>Version numérique envoyée immédiatement, original papier expédié par courrier suivi sous 24h.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TARIFS ============ -->
  <section class="pricing" id="tarifs">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Tarifs</span>
        <h2>Un prix clair, annoncé avant traduction</h2>
        <p>Le tarif définitif dépend de la langue, de la longueur et de la complexité du document. Il vous est toujours confirmé avant le lancement de la traduction.</p>
      </div>

      <div class="price-table">
        <div class="price-row head">
          <div class="cell">Type de document</div>
          <div class="cell">Tarif indicatif</div>
        </div>
        <div class="price-row featured">
          <div class="cell">Acte d'état civil (naissance, mariage…)</div>
          <div class="cell">À partir de 28€ / page</div>
        </div>
        <div class="price-row">
          <div class="cell">Diplôme ou relevé de notes</div>
          <div class="cell">À partir de 35€ / page</div>
        </div>
        <div class="price-row">
          <div class="cell">Jugement, contrat, acte notarié</div>
          <div class="cell">Sur devis selon volume</div>
        </div>
        <div class="price-row">
          <div class="cell">Casier judiciaire / attestation courte</div>
          <div class="cell">À partir de 28€ / page</div>
        </div>
      </div>

      <p class="price-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
        Le tarif de 28€ s'applique aux documents standards d'une page en anglais, espagnol, italien ou allemand. Les langues rares, les documents longs ou les mentions manuscrites peuvent faire varier le prix — toujours communiqué avant validation.
      </p>
    </div>
  </section>

  <!-- ============ POURQUOI NOUS ============ -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Pourquoi cette traduction est reconnue</span>
        <h2>Une traduction assermentée n'est pas une traduction comme les autres</h2>
      </div>

      <div class="why-grid">
        <div class="why-item">
          <span class="why-num">A</span>
          <div>
            <h3>Inscription officielle près de la Cour d'Appel</h3>
            <p>La traduction porte un cachet et une signature reconnus par les juridictions, préfectures et organismes publics français.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-num">B</span>
          <div>
            <h3>Conformité ligne à ligne</h3>
            <p>Chaque mention du document d'origine — tampons, signatures, annotations marginales — est restituée, rien n'est omis.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-num">C</span>
          <div>
            <h3>Numéro de répertoire traçable</h3>
            <p>Chaque traduction est enregistrée sous un numéro unique, consultable en cas de vérification par une administration.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-num">D</span>
          <div>
            <h3>Recevable à l'international</h3>
            <p>Reconnue par la majorité des ambassades et administrations étrangères, avec apostille sur demande si nécessaire.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section id="faq">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Questions fréquentes</span>
        <h2>Avant de nous confier votre document</h2>
      </div>

      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-q">Qu'est-ce qu'une traduction assermentée exactement ?<span class="plus">+</span></summary>
          <div class="faq-a">C'est une traduction réalisée par un traducteur inscrit près d'une Cour d'Appel, qui certifie sur le document que la traduction est conforme à l'original. Elle porte un cachet, une signature et un numéro de répertoire, ce qui lui donne une valeur officielle devant les administrations et tribunaux.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Le tarif de 28€ s'applique-t-il à tous les documents ?<span class="plus">+</span></summary>
          <div class="faq-a">Ce tarif de base concerne les documents courts et standards (un acte d'une page, dans une langue courante). Les documents longs, les langues rares ou les mentions manuscrites peuvent légèrement augmenter le prix — vous recevez toujours un devis précis avant tout engagement.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Combien de temps pour recevoir ma traduction ?<span class="plus">+</span></summary>
          <div class="faq-a">Le délai moyen est de 24 à 48 heures pour un document standard. La version numérique certifiée vous est envoyée dès la fin de la traduction ; l'original papier avec cachet est expédié par courrier suivi le jour même.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Ma traduction sera-t-elle acceptée à l'étranger ?<span class="plus">+</span></summary>
          <div class="faq-a">Dans la grande majorité des cas, oui. Certains pays exigent en plus une apostille ou une légalisation, démarche que nous pouvons vous indiquer selon votre destination.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Dois-je envoyer le document original par courrier ?<span class="plus">+</span></summary>
          <div class="faq-a">Non, un scan ou une photo nette et lisible suffit pour démarrer la traduction. L'original ne vous sera demandé que si l'administration destinataire l'exige spécifiquement.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="cta-final" id="contact">
    <div class="wrap">
      <span class="eyebrow" style="color:#fdfdfd;justify-content:center;">Démarrer votre dossier</span>
      <h2>Envoyez votre document, recevez votre devis sous 2h</h2>
      <p>Indiquez votre adresse e-mail, nous vous recontactons avec le tarif exact et le délai pour votre document.</p>
      <form class="cta-final-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Demande envoyée ✓';">
        <input type="email" placeholder="votre@email.fr" required aria-label="Votre adresse e-mail">
        <button type="submit">Recevoir mon devis</button>
      </form>
    </div>
  </section>

</main>

