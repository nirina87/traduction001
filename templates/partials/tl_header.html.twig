{% set current_route = app.request.attributes.get('_route') %}
{% set cartCount = app.session.get('cart', [])|length %}

<header class="topbar">
  <div class="topbar__contact">
    <div class="wrap">
      <div class="topbar__contact-links">
        <a href="tel:+33187663433">01 87 66 34 33</a>
        <span class="topbar__contact-sep" aria-hidden="true">·</span>
        <a href="mailto:contact@traductions-legales.fr">contact@traductions-legales.fr</a>
      </div>
    </div>
  </div>
  <div class="topbar__rule" role="presentation"></div>
  <div class="wrap topbar__main">
    <a href="{{ path('accueil') }}" class="brand">
      <img src="{{ asset('logo-tl.png') }}" alt="Traductions Légales — Traductions assermentées">
    </a>
    <button class="nav-burger" type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="main-nav">
      <span class="nav-burger__bar" aria-hidden="true"></span>
      <span class="nav-burger__bar" aria-hidden="true"></span>
      <span class="nav-burger__bar" aria-hidden="true"></span>
    </button>
    <nav id="main-nav" class="main-nav" aria-label="Navigation principale">
      <a href="{{ path('accueil') }}" class="{{ current_route == 'accueil' ? 'is-active' : '' }}">Accueil</a>
      <a href="{{ path('services') }}" class="{{ current_route in ['services', 'document_detail'] ? 'is-active' : '' }}">Services</a>
      <a href="{{ path('qui_sommes_nous') }}" class="{{ current_route == 'qui_sommes_nous' ? 'is-active' : '' }}">Qui sommes-nous</a>
      <a href="{{ path('contact') }}" class="{{ current_route == 'contact' ? 'is-active' : '' }}">Contact</a>
      <div class="nav-actions">
        <a href="{{ path('panier') }}" class="nav-panier{{ current_route in ['panier', 'commande'] ? ' is-active' : '' }}">
          Mon panier{% if cartCount > 0 %} <span class="nav-badge">{{ cartCount }}</span>{% endif %}
        </a>
        <a href="{{ path('contact') }}" class="nav-cta">Demander un devis</a>
      </div>
    </nav>
  </div>
</header>
